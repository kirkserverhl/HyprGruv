/* Launcher shared colors — now sourced from matugen for wallpaper-driven theming */
@import "~/.config/rofi/colors.rasi"

/* Provide the simple names many launcher styles expect */
* {
    background:      @surface-container-low;
    background-alt:  @surface-container;
    foreground:      @on-surface;
    selected:        @primary;
    active:          @secondary;
    urgent:          @error;
}
