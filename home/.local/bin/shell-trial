#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: shell-trial <command>

Commands:
  fish          Start fish (user-local install if system fish missing)
  zsh           Start zsh with your normal config
  install       Install fish system-wide via yay (needs sudo)
  default-fish  Set login shell to fish (needs sudo + install)
  default-zsh   Restore login shell to zsh
  compare       Show zsh vs fish feature mapping
  backup        Re-backup zsh config to ~/.config/zsh-backup-DATE

Your zsh config is untouched. Default shell stays zsh until you run default-fish.
EOF
}

fish_bin() {
    if command -v fish >/dev/null 2>&1; then
        command -v fish
    elif [[ -x "$HOME/.local/fish-root/usr/bin/fish" ]]; then
        echo "$HOME/.local/fish-root/usr/bin/fish"
    else
        echo "fish not found — run: shell-trial install" >&2
        return 1
    fi
}

cmd="${1:-}"
case "$cmd" in
    fish)
        exec "$(fish_bin)"
        ;;
    zsh)
        exec zsh
        ;;
    install)
        yay -S fish
        ;;
    default-fish)
        fish_path="$(fish_bin)"
        if [[ "$fish_path" == "$HOME/.local/bin/fish" ]]; then
            fish_path="$HOME/.local/fish-root/usr/bin/fish"
        fi
        if [[ ! -f /etc/shells ]] || ! grep -Fxq "$fish_path" /etc/shells 2>/dev/null; then
            echo "Adding $fish_path to /etc/shells (sudo required)…"
            echo "$fish_path" | sudo tee -a /etc/shells >/dev/null
        fi
        chsh -s "$fish_path"
        echo "Login shell set to $fish_path — reboot or log out/in to apply"
        ;;
    default-zsh)
        chsh -s /usr/bin/zsh
        echo "Login shell restored to /usr/bin/zsh"
        ;;
    backup)
        dest="$HOME/.config/zsh-backup-$(date +%Y%m%d-%H%M%S)"
        mkdir -p "$dest"
        cp -a "$HOME/.zshrc" "$HOME/.zprofile" "$dest/"
        if [[ -L "$HOME/.zshenv" ]]; then
            cp -L "$HOME/.zshenv" "$dest/zshenv"
        elif [[ -f "$HOME/.zshenv" ]]; then
            cp -a "$HOME/.zshenv" "$dest/zshenv"
        fi
        echo "Backed up to $dest"
        ;;
    compare)
        cat <<'EOF'
Zsh setup                          Fish equivalent
─────────────────────────────────────────────────────────────
Oh My Zsh                          Not needed (fish is opinionated)
zsh-autosuggestions                Built-in fish autosuggestions
zsh-syntax-highlighting            Built-in fish syntax highlighting
git plugin                         Built-in git completions
Starship                           starship init fish
FZF                                fzf_key_bindings (from fish pkg)
Zoxide                             zoxide init fish
Atuin                              atuin init fish
The Fuck                           thefuck --alias | source
Matugen OSC reload                 conf.d/30-matugen.fish
Aliases / functions                conf.d/20-aliases.fish + functions/
Grok completions                   ~/.config/fish/completions/grok.fish

Try fish now:  shell-trial fish
Back to zsh:   shell-trial zsh   (or just type zsh)
EOF
        ;;
    ""|-h|--help|help)
        usage
        ;;
    *)
        echo "Unknown command: $cmd" >&2
        usage
        exit 1
        ;;
esac