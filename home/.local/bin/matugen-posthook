#!/usr/bin/env bash
# Matugen Post Hook
#
# Runs after every successful matugen invocation (configured in ~/.config/matugen/config.toml).
#
# Responsibilities:
#   - Produce clean, always-valid cache files that other tools/scripts can consume:
#       ~/.cache/matugen/current.json          (full matugen JSON)
#       ~/.cache/matugen/colors.sh             (directly sourceable shell exports)
#   - Handle grayscale wallpaper edge cases
#
# These files power dynamic theming for gum, waybar, yazi, etc.

WALLPAPER="$1"
if [[ -z "$WALLPAPER" ]]; then
    WALLPAPER="(color source)"
fi

CACHE_DIR="${HOME}/.cache/matugen"
JSON_CACHE="${CACHE_DIR}/current.json"
SHELL_CACHE="${CACHE_DIR}/colors.sh"
GRAYSCALE_THRESHOLD=0.08

mkdir -p "$CACHE_DIR"

is_mostly_grayscale() {
    local img="$1"
    local mean_sat
    mean_sat=$(magick "$img" -colorspace HSL -channel S -separate -format "%[fx:mean]" info: 2>/dev/null)

    [ -z "$mean_sat" ] && return 1

    if awk "BEGIN { exit !($mean_sat < $GRAYSCALE_THRESHOLD) }"; then
        return 0
    else
        return 1
    fi
}

# -----------------------------------------------------------------------------
# Generate fresh matugen data
# -----------------------------------------------------------------------------
MATUGEN_JSON=""
matugen_args=()

if [[ ! -f "$WALLPAPER" ]]; then
    echo "[posthook] Color-hex mode — rebuilding JSON cache from current wallpaper + source color 1"
    WP_CACHE="$HOME/.config/settings/cache/current_wallpaper"
    if [[ -f "$WP_CACHE" ]]; then
        WALLPAPER=$(cat "$WP_CACHE")
    fi
fi

if [[ -f "$WALLPAPER" ]] && command -v matugen >/dev/null 2>&1; then
    EXTRACTOR="$HOME/.config/hypr/scripts/extract-good-source-colors.sh"
    SRC="#a78a9d"
    if [[ -x "$EXTRACTOR" ]]; then
        SRC=$("$EXTRACTOR" "$WALLPAPER" 1 2>/dev/null | head -1)
        [[ -z "$SRC" ]] && SRC="#a78a9d"
    fi

    if is_mostly_grayscale "$WALLPAPER"; then
        echo ":: [posthook] Mostly grayscale wallpaper → neutral source"
        SRC="#0f0f0f"
    fi

    echo ":: [posthook] Source color 1: $SRC (from $(basename "$WALLPAPER"))"
    RAW=$(matugen color hex "$SRC" --mode dark --type scheme-tonal-spot --dry-run --json hex 2>/dev/null || true)
elif command -v matugen >/dev/null 2>&1; then
    RAW=""
fi

# Legacy image-only path (if something still calls posthook with a bare image path)
if [[ -z "$RAW" && -f "$WALLPAPER" ]] && command -v matugen >/dev/null 2>&1; then
    matugen_args=(--mode dark --type scheme-tonal-spot --source-color-index 0 --dry-run)
    if is_mostly_grayscale "$WALLPAPER"; then
        matugen_args=(--mode dark --type scheme-tonal-spot --fallback-color "#0f0f0f" --dry-run)
    fi
    RAW=$(matugen image "$WALLPAPER" "${matugen_args[@]}" --json hex 2>/dev/null || true)
fi

# Strip common noise ("ok", empty lines, etc.) then validate
CLEAN=""
if [[ -n "${RAW:-}" ]]; then
    CLEAN=$(printf '%s\n' "$RAW" | sed '/^ok$/d' | sed '/^[[:space:]]*$/d')
    if echo "$CLEAN" | jq -e '.colors | type == "object"' >/dev/null 2>&1; then
        MATUGEN_JSON="$CLEAN"
    fi
fi

# -----------------------------------------------------------------------------
# Write current.json (only if valid)
# -----------------------------------------------------------------------------
if [[ -n "$MATUGEN_JSON" ]] && echo "$MATUGEN_JSON" | jq -e '.colors | type == "object"' >/dev/null 2>&1; then
    echo "$MATUGEN_JSON" > "$JSON_CACHE"
    echo ":: [posthook] Wrote clean JSON cache"
    # Snapshot JSON per wallpaper for offline reuse / debugging
    if [[ -f "$WALLPAPER" ]]; then
        SNAP_DIR="${CACHE_DIR}/snapshots"
        mkdir -p "$SNAP_DIR"
        wp_base=$(basename "$WALLPAPER" | tr '/ ' '__')
        cp -f "$JSON_CACHE" "${SNAP_DIR}/${wp_base}.json" 2>/dev/null || true
    fi
else
    echo ":: [posthook] WARNING: matugen did not return usable JSON for $WALLPAPER" >&2
fi

JSON_TMP=""
if [[ -f "$JSON_CACHE" ]] && [[ -s "$JSON_CACHE" ]]; then
    JSON_TMP="$JSON_CACHE"
fi

# -----------------------------------------------------------------------------
# Write colors.sh — directly sourceable, used by gum / scripts / etc.
# -----------------------------------------------------------------------------
if [[ -n "$JSON_TMP" ]]; then
    python3 - "$JSON_TMP" > "$SHELL_CACHE" <<'PYEOF'
import sys, json

def normalize_colors(data):
    raw = data.get("colors", {})
    if isinstance(raw.get("default"), dict) and any(
        isinstance(v, dict) and "hex" in v for v in raw["default"].values()
    ):
        return raw["default"]
    out = {}
    for name, val in raw.items():
        if not isinstance(val, dict):
            continue
        if "hex" in val:
            out[name] = val
        elif isinstance(val.get("default"), dict):
            color = val["default"].get("color") or val["default"].get("hex")
            if color:
                out[name] = {"hex": color}
    return out

data = json.loads(open(sys.argv[1], encoding="utf-8").read())
colors = normalize_colors(data)

lines = [
    "#!/usr/bin/env bash",
    "# Auto-generated by matugen-posthook — do not edit manually.",
    "# Source this file to get COLOR_* variables matching the current wallpaper.",
    "",
    "export MATUGEN_THEME_ACTIVE=1",
]

for name, val in sorted(colors.items()):
    if isinstance(val, dict) and "hex" in val:
        hexval = val["hex"]
        var = "COLOR_" + name.upper().replace("-", "_")
        lines.append(f'export {var}="{hexval}"')

# Add a few very common semantic aliases for convenience
aliases = [
    ('COLOR_ACCENT',        'COLOR_PRIMARY'),
    ('COLOR_BG',            'COLOR_SURFACE'),
    ('COLOR_FG',            'COLOR_ON_SURFACE'),
    ('COLOR_TEXT',          'COLOR_ON_SURFACE'),
    ('COLOR_SURFACE_CONTAINER_HIGH', 'COLOR_SURFACE_CONTAINER_HIGH'),
]
for alias, target in aliases:
    lines.append(f'export {alias}="${{{target}}}"')

print("\n".join(lines))
PYEOF
    chmod +x "$SHELL_CACHE"
    echo ":: [posthook] Wrote shell color cache: $SHELL_CACHE"

    # gum.env — pre-baked GUM_* exports for installer scripts / subprocesses
    GUM_ENV="${CACHE_DIR}/gum.env"
    COLORS_SH="${HOME}/.config/hypr/scripts/colors.sh"
    if [[ -f "$COLORS_SH" ]]; then
        {
            echo "#!/usr/bin/env bash"
            echo "# Auto-generated by matugen-posthook — source before gum commands."
            bash -c "source '$COLORS_SH' --gum 2>/dev/null; env | grep '^GUM_'" \
                | sed 's/^/export /' || true
        } >"$GUM_ENV"
    else
        {
            echo "#!/usr/bin/env bash"
            echo "# Auto-generated by matugen-posthook — source before gum commands."
            bash -c "set -a; source '$SHELL_CACHE'; set +a
COLOR_ON_SURFACE_VARIANT=\"\${COLOR_ON_SURFACE_VARIANT:-#bac2de}\"
COLOR_SURFACE_CONTAINER=\"\${COLOR_SURFACE_CONTAINER:-#252535}\"
export GUM_CONFIRM_SELECTED_BACKGROUND=\"\${COLOR_PRIMARY}\"
export GUM_CONFIRM_SELECTED_FOREGROUND=\"\${COLOR_ON_PRIMARY}\"
export GUM_CONFIRM_UNSELECTED_BACKGROUND=\"\${COLOR_SURFACE_CONTAINER}\"
export GUM_CONFIRM_UNSELECTED_FOREGROUND=\"\${COLOR_ON_SURFACE}\"
export GUM_INPUT_CURSOR_FOREGROUND=\"\${COLOR_PRIMARY}\"
export GUM_INPUT_PROMPT_FOREGROUND=\"\${COLOR_PRIMARY}\"
export GUM_CHOOSE_SELECTED_FOREGROUND=\"\${COLOR_PRIMARY}\"
export GUM_SPIN_SPINNER_FOREGROUND=\"\${COLOR_PRIMARY}\"
env | grep '^GUM_'" | sed 's/^/export /' || true
        } >"$GUM_ENV"
    fi
    chmod +x "$GUM_ENV" 2>/dev/null || true
    echo ":: [posthook] Wrote gum theme cache: $GUM_ENV"
fi

# -----------------------------------------------------------------------------
# Starship fallback — only if the matugen template did not write the file.
# The main [templates.starship_rainbow] entry is the source of truth; this
# defensive copy used to overwrite it and could desync colors from kitty/gtk.
# -----------------------------------------------------------------------------
STARSHIP_OUT="$HOME/.config/starship/matugen-rainbow.toml"
if [ -n "$JSON_TMP" ] && { [ ! -s "$STARSHIP_OUT" ] || [ ! -s "$JSON_CACHE" ]; }; then
    python3 - "$JSON_TMP" > /tmp/starship-render.toml <<'PYEOF'
import sys, json, os

data = json.loads(open(sys.argv[1], encoding="utf-8").read())

def normalize_colors(data):
    raw = data.get("colors", {})
    if isinstance(raw.get("default"), dict) and any(
        isinstance(v, dict) and "hex" in v for v in raw["default"].values()
    ):
        return raw["default"]
    out = {}
    for name, val in raw.items():
        if not isinstance(val, dict):
            continue
        if "hex" in val:
            out[name] = val
        elif isinstance(val.get("default"), dict):
            color = val["default"].get("color") or val["default"].get("hex")
            if color:
                out[name] = {"hex": color}
    return out

colors = normalize_colors(data)

def getc(name, fallback="#888888"):
    c = colors.get(name, {})
    return c.get("hex", fallback) if isinstance(c, dict) else fallback

primary = getc("primary")
on_primary = getc("on_primary")
secondary = getc("secondary")
on_secondary = getc("on_secondary")
tertiary = getc("tertiary")
on_tertiary = getc("on_tertiary")
primary_container = getc("primary_container")
surface_container = getc("surface_container")
surface_container_high = getc("surface_container_high")
on_surface = getc("on_surface")
error = getc("error")

content = f'''# =============================================================================
# Starship Rainbow Prompt — Matugen (auto-generated via posthook)
# =============================================================================
# Written by ~/.local/bin/matugen-posthook from current.json
# Source template: ~/.config/matugen/templates/starship-rainbow.toml
#
# This is a defensive copy. The main template entry in matugen/config.toml
# should also keep this file up to date on wallpaper changes.

format = """
[](color_orange)\\
$os\\
$username\\
[](bg:color_yellow fg:color_orange)\\
$directory\\
[](fg:color_yellow bg:color_aqua)\\
$git_branch\\
$git_status\\
[](fg:color_aqua bg:color_blue)\\
$c\\
$cpp\\
$rust\\
$golang\\
$nodejs\\
$bun\\
$php\\
$java\\
$kotlin\\
$haskell\\
$python\\
[](fg:color_blue bg:color_bg3)\\
$docker_context\\
$conda\\
$pixi\\
[](fg:color_bg3 bg:color_bg1)\\
$time\\
[ ](fg:color_bg1)\\
$line_break$character"""

palette = 'matugen'

[palettes.matugen]
color_fg0 = '{on_surface}'
color_bg1 = '{surface_container}'
color_bg3 = '{surface_container_high}'

color_orange = '{primary}'
color_yellow = '{tertiary}'
color_aqua   = '{secondary}'
color_blue   = '{primary_container}'

color_on_orange = '{on_primary}'
color_on_yellow = '{on_tertiary}'
color_on_aqua   = '{on_secondary}'

color_green  = '{secondary}'
color_red    = '{error}'
color_purple = '{tertiary}'

[os]
disabled = false
style = "bg:color_orange fg:color_on_orange"

[os.symbols]
Windows = "󰍲"
Ubuntu = "󰕈"
SUSE = ""
Raspbian = "󰐿"
Mint = "󰣭"
Macos = "󰀵"
Manjaro = ""
Linux = "󰌽"
Gentoo = "󰣨"
Fedora = "󰣛"
Alpine = ""
Amazon = ""
Android = ""
AOSC = ""
Arch = "󰣇"
Artix = "󰣇"
EndeavourOS = ""
CentOS = ""
Debian = "󰣚"
Redhat = "󱄛"
RedHatEnterprise = "󱄛"
Pop = ""

[username]
show_always = true
style_user = "bg:color_orange fg:color_on_orange"
style_root = "bg:color_orange fg:color_on_orange"
format = '[ $user ]($style)'

[directory]
style = "fg:color_on_yellow bg:color_yellow"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "…/"

[directory.substitutions]
"Documents" = "󰈙 "
"Downloads" = " "
"Music" = "󰝚 "
"Pictures" = " "
"Developer" = "󰲋 "

[git_branch]
symbol = ""
style = "bg:color_aqua"
format = '[[ $symbol $branch ](fg:color_on_aqua bg:color_aqua)]($style)'

[git_status]
style = "bg:color_aqua"
format = '[[($all_status$ahead_behind )](fg:color_on_aqua bg:color_aqua)]($style)'

[nodejs]
symbol = ""
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[bun]
symbol = ""
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[c]
symbol = " "
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[cpp]
symbol = " "
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[rust]
symbol = ""
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[golang]
symbol = ""
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[php]
symbol = ""
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[java]
symbol = ""
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[kotlin]
symbol = ""
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[haskell]
symbol = ""
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[python]
symbol = ""
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[docker_context]
symbol = ""
style = "bg:color_bg3"
format = '[[ $symbol( $context) ](fg:color_fg0 bg:color_bg3)]($style)'

[conda]
style = "bg:color_bg3"
format = '[[ $symbol( $environment) ](fg:color_fg0 bg:color_bg3)]($style)'

[pixi]
style = "bg:color_bg3"
format = '[[ $symbol( $version)( $environment) ](fg:color_fg0 bg:color_bg3)]($style)'

[time]
disabled = false
time_format = "%R"
style = "bg:color_bg1"
format = '[[  $time ](fg:color_fg0 bg:color_bg1)]($style)'

[line_break]
disabled = false

[character]
disabled = false
success_symbol = '[](bold fg:color_green)'
error_symbol = '[](bold fg:color_red)'
vimcmd_symbol = '[](bold fg:color_green)'
vimcmd_replace_one_symbol = '[](bold fg:color_purple)'
vimcmd_replace_symbol = '[](bold fg:color_purple)'
vimcmd_visual_symbol = '[](bold fg:color_yellow)'
'''

# escape the backslashes for the actual TOML (the prompt uses literal \uE0B6 etc in the real file)
print(content)
PYEOF

    if [ -s /tmp/starship-render.toml ]; then
        mkdir -p ~/.config/starship
        cp /tmp/starship-render.toml "$STARSHIP_OUT"
        echo ":: [posthook] Wrote fallback ~/.config/starship/matugen-rainbow.toml"
    fi
elif [ -s "$STARSHIP_OUT" ]; then
    touch "$STARSHIP_OUT" 2>/dev/null || true
    echo ":: [posthook] Starship config left to matugen template ($STARSHIP_OUT)"
fi

# Waybar themes import colors/matugen-waybar.css via shared/base.css — no root colors.css sync needed.

# Note: waybar-transparent-this-time is handled by set_wallpaper.sh (and palette.sh)
# *after* a full matugen run. The posthook always writes the complete themed file;
# the toggle script then punches holes in just the background roles.

# -----------------------------------------------------------------------------
# TTY (virtual console) palette - so Ctrl+Alt+F3 etc. match the current theme
# -----------------------------------------------------------------------------
"$HOME/.config/hypr/scripts/tty-theme.sh" 2>/dev/null || true &

# -----------------------------------------------------------------------------
# Plymouth splash theme (if installed and configured)
# This is backgrounded because it may need to elevate for /usr/share
# -----------------------------------------------------------------------------
"$HOME/.config/hypr/scripts/update-plymouth-theme.sh" 2>/dev/null || true &

echo "Matugen post-hook completed for: $(basename "$WALLPAPER" 2>/dev/null || echo "$WALLPAPER")"
