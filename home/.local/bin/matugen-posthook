#!/usr/bin/env bash
# Matugen Post Hook
#
# Runs after every successful matugen invocation (configured in ~/.config/matugen/config.toml).
#
# Responsibilities:
#   - Produce clean, always-valid cache files that other tools/scripts can consume:
#       ~/.cache/matugen/current.json          (full matugen JSON)
#       ~/.cache/matugen/colors.sh             (directly sourceable shell exports)
#   - Honor ~/.cache/matugen/force-monochrome (set by palette.sh only)
#
# These files power dynamic theming for gum, waybar, yazi, etc.

WALLPAPER="$1"
if [[ -z "$WALLPAPER" ]]; then
    WALLPAPER="(color source)"
fi

CACHE_DIR="${HOME}/.cache/matugen"
JSON_CACHE="${CACHE_DIR}/current.json"
SHELL_CACHE="${CACHE_DIR}/colors.sh"
PENDING_RUN="${CACHE_DIR}/pending-run.json"
FORCE_MONO_FLAG="${CACHE_DIR}/force-monochrome"

mkdir -p "$CACHE_DIR"

# pending-run.json (written by apply-matugen-auto) is authoritative for hex/image
# mode and the wallpaper being themed — matugen color hex passes no {{image}} path.
RUN_METHOD="hex"
RUN_COLOR_MODE="material"
RUN_MODE="dark"
RUN_TYPE="scheme-tonal-spot"
SOURCE_INDEX=0
SRC_HEX="#a78a9d"
PENDING_WP=""
WAL_IMPORT_JSON="${CACHE_DIR}/wal-import.json"
WAL_BRIDGE="${HOME}/.config/hyprgruv/scripts/wal-to-matugen-import.sh"

if [[ -f "$PENDING_RUN" ]]; then
    RUN_METHOD=$(jq -r '.method // "hex"' "$PENDING_RUN" 2>/dev/null || echo "hex")
    RUN_COLOR_MODE=$(jq -r '.color_mode // "material"' "$PENDING_RUN" 2>/dev/null || echo "material")
    RUN_MODE=$(jq -r '.mode // "dark"' "$PENDING_RUN" 2>/dev/null || echo "dark")
    RUN_TYPE=$(jq -r '.type // "scheme-tonal-spot"' "$PENDING_RUN" 2>/dev/null || echo "scheme-tonal-spot")
    SOURCE_INDEX=$(jq -r '.source_index // 0' "$PENDING_RUN" 2>/dev/null || echo 0)
    SRC_HEX=$(jq -r '.source_hex // "#a78a9d"' "$PENDING_RUN" 2>/dev/null || echo "#a78a9d")
    PENDING_WP=$(jq -r '.wallpaper // empty' "$PENDING_RUN" 2>/dev/null || true)
fi

if [[ -n "$PENDING_WP" && -f "$PENDING_WP" ]]; then
    WALLPAPER="$PENDING_WP"
elif [[ ! -f "$WALLPAPER" ]]; then
    echo "[posthook] No image arg — reading current wallpaper cache"
    WP_CACHE="$HOME/.config/settings/cache/current_wallpaper"
    if [[ -f "$WP_CACHE" ]]; then
        WALLPAPER=$(cat "$WP_CACHE")
    fi
fi

# -----------------------------------------------------------------------------
# Generate fresh matugen data (must match pending-run / apply-matugen-auto)
# -----------------------------------------------------------------------------
MATUGEN_JSON=""
matugen_args=()

if [[ -f "$FORCE_MONO_FLAG" ]]; then
    RUN_TYPE="scheme-monochrome"
    echo ":: [posthook] palette.sh monochrome — scheme-monochrome"
fi

if [[ -f "$WALLPAPER" ]] && command -v matugen >/dev/null 2>&1; then
    if [[ "$RUN_METHOD" == "wal" ]]; then
        echo ":: [posthook] JSON cache: pywal import ($(basename "$WALLPAPER"))"
        if [[ -x "$WAL_BRIDGE" ]]; then
            "$WAL_BRIDGE" "$WALLPAPER" "$WAL_IMPORT_JSON" >/dev/null 2>&1 || true
        fi
        if [[ -f "$WAL_IMPORT_JSON" ]] && jq -e '.colors | type == "object"' "$WAL_IMPORT_JSON" >/dev/null 2>&1; then
            RAW=$(jq -c '.' "$WAL_IMPORT_JSON" 2>/dev/null || true)
        fi
    elif [[ "$RUN_METHOD" == "image" ]]; then
        echo ":: [posthook] JSON cache: image mode index=$SOURCE_INDEX type=$RUN_TYPE ($(basename "$WALLPAPER"))"
        RAW=$(matugen image "$WALLPAPER" --mode "$RUN_MODE" --type "$RUN_TYPE" --source-color-index "$SOURCE_INDEX" --dry-run --json hex 2>/dev/null || true)
    else
        echo ":: [posthook] JSON cache: hex mode source=$SRC_HEX type=$RUN_TYPE"
        RAW=$(matugen color hex "$SRC_HEX" --mode "$RUN_MODE" --type "$RUN_TYPE" --dry-run --json hex 2>/dev/null || true)
    fi
elif command -v matugen >/dev/null 2>&1; then
    RAW=""
fi

# Strip common noise ("ok", empty lines, etc.) then validate
CLEAN=""
if [[ -n "${RAW:-}" ]]; then
    CLEAN=$(printf '%s\n' "$RAW" | sed '/^ok$/d' | sed '/^[[:space:]]*$/d')
    if echo "$CLEAN" | jq -e '.colors | type == "object"' >/dev/null 2>&1; then
        MATUGEN_JSON="$CLEAN"
    fi
fi

# -----------------------------------------------------------------------------
# Write current.json (only if valid)
# -----------------------------------------------------------------------------
if [[ -n "$MATUGEN_JSON" ]] && echo "$MATUGEN_JSON" | jq -e '.colors | type == "object"' >/dev/null 2>&1; then
    echo "$MATUGEN_JSON" > "$JSON_CACHE"
    echo ":: [posthook] Wrote clean JSON cache"
    # Snapshot JSON per wallpaper for offline reuse / debugging
    if [[ -f "$WALLPAPER" ]]; then
        SNAP_DIR="${CACHE_DIR}/snapshots"
        mkdir -p "$SNAP_DIR"
        wp_base=$(basename "$WALLPAPER" | tr '/ ' '__')
        cp -f "$JSON_CACHE" "${SNAP_DIR}/${wp_base}.json" 2>/dev/null || true
    fi
else
    echo ":: [posthook] WARNING: matugen did not return usable JSON for $WALLPAPER" >&2
fi

JSON_TMP=""
if [[ -f "$JSON_CACHE" ]] && [[ -s "$JSON_CACHE" ]]; then
    JSON_TMP="$JSON_CACHE"
fi

# -----------------------------------------------------------------------------
# Write colors.sh — directly sourceable, used by gum / scripts / etc.
# -----------------------------------------------------------------------------
if [[ -n "$JSON_TMP" ]]; then
    python3 - "$JSON_TMP" > "$SHELL_CACHE" <<'PYEOF'
import sys, json

def normalize_colors(data):
    raw = data.get("colors", {})
    if isinstance(raw.get("default"), dict) and any(
        isinstance(v, dict) and "hex" in v for v in raw["default"].values()
    ):
        return raw["default"]
    out = {}
    for name, val in raw.items():
        if not isinstance(val, dict):
            continue
        if "hex" in val:
            out[name] = val
        elif isinstance(val.get("default"), dict):
            color = val["default"].get("color") or val["default"].get("hex")
            if color:
                out[name] = {"hex": color}
    return out

data = json.loads(open(sys.argv[1], encoding="utf-8").read())
colors = normalize_colors(data)

lines = [
    "#!/usr/bin/env bash",
    "# Auto-generated by matugen-posthook — do not edit manually.",
    "# Source this file to get COLOR_* variables matching the current wallpaper.",
    "",
    "export MATUGEN_THEME_ACTIVE=1",
]

for name, val in sorted(colors.items()):
    if isinstance(val, dict) and "hex" in val:
        hexval = val["hex"]
        var = "COLOR_" + name.upper().replace("-", "_")
        lines.append(f'export {var}="{hexval}"')

# Base16 palette exports (Material You → semantic slots)
BASE16_MAP = {
    "base00": "surface_container_lowest",
    "base01": "surface_container_low",
    "base02": "surface_container",
    "base03": "outline_variant",
    "base04": "on_surface_variant",
    "base05": "on_surface",
    "base06": "inverse_on_surface",
    "base07": "surface_bright",
    "base08": "error",
    "base09": "tertiary",
    "base0a": "secondary",
    "base0b": "primary",
    "base0c": "tertiary_container",
    "base0d": "primary",
    "base0e": "secondary_container",
    "base0f": "source_color",
}
for slot, material in BASE16_MAP.items():
    val = colors.get(material, {})
    hexval = val.get("hex") if isinstance(val, dict) else None
    if hexval:
        lines.append(f'export BASE16_{slot.upper()}="{hexval}"')

# Add a few very common semantic aliases for convenience
aliases = [
    ('COLOR_ACCENT',        'BASE16_BASE0D'),
    ('COLOR_BG',            'COLOR_SURFACE'),
    ('COLOR_FG',            'COLOR_ON_SURFACE'),
    ('COLOR_TEXT',          'COLOR_ON_SURFACE'),
    ('COLOR_SURFACE_CONTAINER_HIGH', 'COLOR_SURFACE_CONTAINER_HIGH'),
    ('COLOR_BACKGROUND',    'BASE16_BASE00'),
    ('COLOR_SURFACE',       'BASE16_BASE00'),
    ('COLOR_ON_SURFACE',    'BASE16_BASE05'),
    ('COLOR_PRIMARY',       'BASE16_BASE0D'),
    ('COLOR_ERROR',         'BASE16_BASE08'),
    ('COLOR_URGENT',        'BASE16_BASE08'),
    ('COLOR_MUTED',         'BASE16_BASE03'),
]
for alias, target in aliases:
    lines.append(f'export {alias}="${{{target}}}"')

print("\n".join(lines))
PYEOF
    chmod +x "$SHELL_CACHE"
    echo ":: [posthook] Wrote shell color cache: $SHELL_CACHE"

    # gum.env — pre-baked GUM_* exports for installer scripts / subprocesses
    GUM_ENV="${CACHE_DIR}/gum.env"
    COLORS_SH="${HOME}/.config/hyprgruv/scripts/colors.sh"
    if [[ -f "$COLORS_SH" ]]; then
        {
            echo "#!/usr/bin/env bash"
            echo "# Auto-generated by matugen-posthook — source before gum commands."
            bash -c "source '$COLORS_SH' --gum 2>/dev/null; env | grep '^GUM_'" \
                | sed 's/^/export /' || true
        } >"$GUM_ENV"
    else
        {
            echo "#!/usr/bin/env bash"
            echo "# Auto-generated by matugen-posthook — source before gum commands."
            bash -c "set -a; source '$SHELL_CACHE'; set +a
COLOR_ON_SURFACE_VARIANT=\"\${COLOR_ON_SURFACE_VARIANT:-#bac2de}\"
COLOR_SURFACE_CONTAINER=\"\${COLOR_SURFACE_CONTAINER:-#252535}\"
export GUM_CONFIRM_SELECTED_BACKGROUND=\"\${COLOR_PRIMARY}\"
export GUM_CONFIRM_SELECTED_FOREGROUND=\"\${COLOR_ON_PRIMARY}\"
export GUM_CONFIRM_UNSELECTED_BACKGROUND=\"\${COLOR_SURFACE_CONTAINER}\"
export GUM_CONFIRM_UNSELECTED_FOREGROUND=\"\${COLOR_ON_SURFACE}\"
export GUM_INPUT_CURSOR_FOREGROUND=\"\${COLOR_PRIMARY}\"
export GUM_INPUT_PROMPT_FOREGROUND=\"\${COLOR_PRIMARY}\"
export GUM_CHOOSE_SELECTED_FOREGROUND=\"\${COLOR_PRIMARY}\"
export GUM_SPIN_SPINNER_FOREGROUND=\"\${COLOR_PRIMARY}\"
env | grep '^GUM_'" | sed 's/^/export /' || true
        } >"$GUM_ENV"
    fi
    chmod +x "$GUM_ENV" 2>/dev/null || true
    echo ":: [posthook] Wrote gum theme cache: $GUM_ENV"
fi

# Grok Build TUI theme (~/.grok/themes/matugen.toml)
"$HOME/.config/hyprgruv/scripts/matugen-posthook-grok.sh" 2>/dev/null || true

# -----------------------------------------------------------------------------
# Starship — matugen template is the only source of truth.
# (Legacy posthook fallback removed: it used the wrong palette + empty segment gaps.)
# -----------------------------------------------------------------------------
STARSHIP_OUT="$HOME/.config/starship/matugen-rainbow.toml"
STARSHIP_ACTIVE="$HOME/.config/starship.toml"

if [ -s "$STARSHIP_OUT" ]; then
    touch "$STARSHIP_OUT" 2>/dev/null || true
    mkdir -p "$(dirname "$STARSHIP_ACTIVE")"
    ln -sfn "$STARSHIP_OUT" "$STARSHIP_ACTIVE" 2>/dev/null || true
    echo ":: [posthook] Starship OK ($STARSHIP_OUT)"
elif [ -n "$JSON_TMP" ]; then
    echo ":: [posthook] WARNING: $STARSHIP_OUT missing — run matugen to render templates/starship-rainbow.toml" >&2
fi

# Waybar themes import colors/matugen-waybar.css via shared/base.css — no root colors.css sync needed.

# Note: waybar-transparent-this-time is handled by set_wallpaper.sh (and palette.sh)
# *after* a full matugen run. The posthook always writes the complete themed file;
# the toggle script then punches holes in just the background roles.

# Per-app reloads run via matugen-posthook-{swaync,terminal,starship,hyprland,waybar}.sh
# on each template's post_hook. Cache hits use reload-matugen-visible.sh instead.

# -----------------------------------------------------------------------------
# TTY (virtual console) palette - so Ctrl+Alt+F3 etc. match the current theme
# -----------------------------------------------------------------------------
"$HOME/.config/hyprgruv/scripts/tty-theme.sh" 2>/dev/null || true &

# Firefox (pywalfox bridge — extension still applies browser chrome colors)
"$HOME/.config/hyprgruv/scripts/matugen-posthook-firefox.sh" 2>/dev/null || true

# Plymouth boot splash is opt-in only — never run during wallpaper changes (pkexec
# used to pop a permission dialog and block matugen). Manual sync:
#   touch ~/.config/settings/plymouth-matugen-sync
#   ~/.config/hyprgruv/scripts/update-plymouth-theme.sh --setup

echo "Matugen post-hook completed for: $(basename "$WALLPAPER" 2>/dev/null || echo "$WALLPAPER")"
