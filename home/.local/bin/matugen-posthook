#!/usr/bin/env bash
# Matugen Post Hook
#
# Runs after every successful matugen invocation (configured in ~/.config/matugen/config.toml).
#
# Responsibilities:
#   - Produce clean, always-valid cache files that other tools/scripts can consume:
#       ~/.cache/matugen/current.json          (full matugen JSON)
#       ~/.cache/matugen/colors.sh             (directly sourceable shell exports)
#   - Handle grayscale wallpaper edge cases
#
# These files power dynamic theming for gum, waybar, yazi, etc.

WALLPAPER="$1"
if [[ -z "$WALLPAPER" ]]; then
    # Called from `matugen color hex` (no image). Still do the useful work.
    WALLPAPER="(color source)"
    echo "[posthook] Running in color-hex mode (no image path)"
fi

CACHE_DIR="${HOME}/.cache/matugen"
JSON_CACHE="${CACHE_DIR}/current.json"
SHELL_CACHE="${CACHE_DIR}/colors.sh"
GRAYSCALE_THRESHOLD=0.08

mkdir -p "$CACHE_DIR"

is_mostly_grayscale() {
    local img="$1"
    local mean_sat
    mean_sat=$(magick "$img" -colorspace HSL -channel S -separate -format "%[fx:mean]" info: 2>/dev/null)

    [ -z "$mean_sat" ] && return 1

    if awk "BEGIN { exit !($mean_sat < $GRAYSCALE_THRESHOLD) }"; then
        return 0
    else
        return 1
    fi
}

# -----------------------------------------------------------------------------
# Generate fresh matugen data
# -----------------------------------------------------------------------------
if [[ ! -f "$WALLPAPER" ]]; then
    echo "[posthook] Non-image argument (likely from 'matugen color hex' or palette.sh) â€” skipping re-generation to avoid errors."
    echo "[posthook] Theme files were already written by the main matugen invocation."
    # The css sync at the bottom will still run.
    echo "Matugen post-hook completed for: $WALLPAPER"
    exit 0
fi

MATUGEN_JSON=""
matugen_args="--mode dark"

if is_mostly_grayscale "$WALLPAPER"; then
    echo ":: [posthook] Mostly grayscale wallpaper â†’ using neutral dark scheme"
    matugen_args+=" --source-color \"#0f0f0f\""
fi

# Capture clean JSON (matugen sometimes prints "ok" or other noise on stdout)
if command -v matugen >/dev/null 2>&1; then
    RAW=$(matugen image "$WALLPAPER" $matugen_args --json hex 2>/dev/null || true)
    # Strip common noise ("ok", empty lines, etc.) then validate
    CLEAN=$(printf '%s\n' "$RAW" | sed '/^ok$/d' | sed '/^[[:space:]]*$/d')
    if echo "$CLEAN" | jq -e '.colors.default' >/dev/null 2>&1; then
        MATUGEN_JSON="$CLEAN"
    else
        # Try python extraction as last resort (same pattern as set_wallpaper.sh)
        MATUGEN_JSON=$(python3 -c '
import sys, json
try:
    data = json.loads(sys.stdin.read())
    print(json.dumps(data))
except Exception:
    print("")
' <<< "$CLEAN" 2>/dev/null || true)
    fi
fi

# -----------------------------------------------------------------------------
# Write current.json (only if valid)
# -----------------------------------------------------------------------------
if [[ -n "$MATUGEN_JSON" ]] && echo "$MATUGEN_JSON" | jq -e '.colors.default' >/dev/null 2>&1; then
    echo "$MATUGEN_JSON" > "$JSON_CACHE"
    echo ":: [posthook] Wrote clean JSON cache"
else
    echo ":: [posthook] WARNING: matugen did not return usable JSON for $WALLPAPER" >&2
fi

# -----------------------------------------------------------------------------
# Write colors.sh â€” directly sourceable, used by gum / scripts / etc.
# -----------------------------------------------------------------------------
if [[ -n "$MATUGEN_JSON" ]]; then
    python3 - "$MATUGEN_JSON" > "$SHELL_CACHE" <<'PYEOF'
import sys, json
data = json.loads(sys.stdin.read())
colors = data.get("colors", {}).get("default", {})

lines = [
    "#!/usr/bin/env bash",
    "# Auto-generated by matugen-posthook â€” do not edit manually.",
    "# Source this file to get COLOR_* variables matching the current wallpaper.",
    "",
    "export MATUGEN_THEME_ACTIVE=1",
]

for name, val in sorted(colors.items()):
    if isinstance(val, dict) and "hex" in val:
        hexval = val["hex"]
        # Normalize to uppercase var name with underscores
        var = "COLOR_" + name.upper().replace("-", "_")
        lines.append(f'export {var}="{hexval}"')

# Add a few very common semantic aliases for convenience
aliases = [
    ('COLOR_ACCENT',        'COLOR_PRIMARY'),
    ('COLOR_BG',            'COLOR_SURFACE'),
    ('COLOR_FG',            'COLOR_ON_SURFACE'),
    ('COLOR_TEXT',          'COLOR_ON_SURFACE'),
    ('COLOR_SURFACE_CONTAINER_HIGH', 'COLOR_SURFACE_CONTAINER_HIGH'),
]
for alias, target in aliases:
    lines.append(f'export {alias}="${{{target}}}"')

print("\n".join(lines))
PYEOF
    chmod +x "$SHELL_CACHE"
    echo ":: [posthook] Wrote shell color cache: $SHELL_CACHE"
fi

# -----------------------------------------------------------------------------
# Guarantee Starship matugen-rainbow.toml is always fresh
# (defensive layer in case the normal template registration has issues)
# -----------------------------------------------------------------------------
if [ -n "$MATUGEN_JSON" ]; then
    python3 - "$MATUGEN_JSON" > /tmp/starship-render.toml <<'PYEOF'
import sys, json, os

data = json.loads(sys.stdin.read())
colors = data.get("colors", {}).get("default", {})

def getc(name, fallback="#888888"):
    c = colors.get(name, {})
    return c.get("hex", fallback) if isinstance(c, dict) else fallback

primary = getc("primary")
on_primary = getc("on_primary")
secondary = getc("secondary")
on_secondary = getc("on_secondary")
tertiary = getc("tertiary")
on_tertiary = getc("on_tertiary")
primary_container = getc("primary_container")
surface_container = getc("surface_container")
surface_container_high = getc("surface_container_high")
on_surface = getc("on_surface")
error = getc("error")

content = f'''# =============================================================================
# Starship Rainbow Prompt â€” Matugen (auto-generated via posthook)
# =============================================================================
# Written by ~/.local/bin/matugen-posthook from current.json
# Source template: ~/.config/matugen/templates/starship-rainbow.toml
#
# This is a defensive copy. The main template entry in matugen/config.toml
# should also keep this file up to date on wallpaper changes.

format = """
[î‚¶](color_orange)\\
$os\\
$username\\
[î‚°](bg:color_yellow fg:color_orange)\\
$directory\\
[î‚°](fg:color_yellow bg:color_aqua)\\
$git_branch\\
$git_status\\
[î‚°](fg:color_aqua bg:color_blue)\\
$c\\
$cpp\\
$rust\\
$golang\\
$nodejs\\
$bun\\
$php\\
$java\\
$kotlin\\
$haskell\\
$python\\
[î‚°](fg:color_blue bg:color_bg3)\\
$docker_context\\
$conda\\
$pixi\\
[î‚°](fg:color_bg3 bg:color_bg1)\\
$time\\
[î‚´ ](fg:color_bg1)\\
$line_break$character"""

palette = 'matugen'

[palettes.matugen]
color_fg0 = '{on_surface}'
color_bg1 = '{surface_container}'
color_bg3 = '{surface_container_high}'

color_orange = '{primary}'
color_yellow = '{tertiary}'
color_aqua   = '{secondary}'
color_blue   = '{primary_container}'

color_on_orange = '{on_primary}'
color_on_yellow = '{on_tertiary}'
color_on_aqua   = '{on_secondary}'

color_green  = '{secondary}'
color_red    = '{error}'
color_purple = '{tertiary}'

[os]
disabled = false
style = "bg:color_orange fg:color_on_orange"

[os.symbols]
Windows = "َ°چ²"
Ubuntu = "َ°•ˆ"
SUSE = "ïŒ”"
Raspbian = "َ°گ؟"
Mint = "َ°£­"
Macos = "َ°€µ"
Manjaro = "ïŒ’"
Linux = "َ°Œ½"
Gentoo = "َ°£¨"
Fedora = "َ°£›"
Alpine = "ïŒ€"
Amazon = "ï‰°"
Android = "îœژ"
AOSC = "ïŒپ"
Arch = "َ°£‡"
Artix = "َ°£‡"
EndeavourOS = "ï†—"
CentOS = "ïŒ„"
Debian = "َ°£ڑ"
Redhat = "َ±„›"
RedHatEnterprise = "َ±„›"
Pop = "ïŒھ"

[username]
show_always = true
style_user = "bg:color_orange fg:color_on_orange"
style_root = "bg:color_orange fg:color_on_orange"
format = '[ $user ]($style)'

[directory]
style = "fg:color_on_yellow bg:color_yellow"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "â€¦/"

[directory.substitutions]
"Documents" = "َ°ˆ™ "
"Downloads" = "ï€™ "
"Music" = "َ°‌ڑ "
"Pictures" = "ï€¾ "
"Developer" = "َ°²‹ "

[git_branch]
symbol = "ïگک"
style = "bg:color_aqua"
format = '[[ $symbol $branch ](fg:color_on_aqua bg:color_aqua)]($style)'

[git_status]
style = "bg:color_aqua"
format = '[[($all_status$ahead_behind )](fg:color_on_aqua bg:color_aqua)]($style)'

[nodejs]
symbol = "îœک"
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[bun]
symbol = "î‌¯"
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[c]
symbol = "îک‍ "
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[cpp]
symbol = "îک‌ "
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[rust]
symbol = "î‍¨"
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[golang]
symbol = "îک§"
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[php]
symbol = "îکˆ"
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[java]
symbol = "î‰–"
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[kotlin]
symbol = "îک´"
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[haskell]
symbol = "îکں"
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[python]
symbol = "îک†"
style = "bg:color_blue"
format = '[[ $symbol( $version) ](fg:color_fg0 bg:color_blue)]($style)'

[docker_context]
symbol = "ïŒˆ"
style = "bg:color_bg3"
format = '[[ $symbol( $context) ](fg:color_fg0 bg:color_bg3)]($style)'

[conda]
style = "bg:color_bg3"
format = '[[ $symbol( $environment) ](fg:color_fg0 bg:color_bg3)]($style)'

[pixi]
style = "bg:color_bg3"
format = '[[ $symbol( $version)( $environment) ](fg:color_fg0 bg:color_bg3)]($style)'

[time]
disabled = false
time_format = "%R"
style = "bg:color_bg1"
format = '[[ ïگ؛ $time ](fg:color_fg0 bg:color_bg1)]($style)'

[line_break]
disabled = false

[character]
disabled = false
success_symbol = '[ïگ²](bold fg:color_green)'
error_symbol = '[ïگ²](bold fg:color_red)'
vimcmd_symbol = '[ïگ´](bold fg:color_green)'
vimcmd_replace_one_symbol = '[ïگ´](bold fg:color_purple)'
vimcmd_replace_symbol = '[ïگ´](bold fg:color_purple)'
vimcmd_visual_symbol = '[ïگ´](bold fg:color_yellow)'
'''

# escape the backslashes for the actual TOML (the prompt uses literal \uE0B6 etc in the real file)
print(content)
PYEOF

    if [ -s /tmp/starship-render.toml ]; then
        mkdir -p ~/.config/starship
        cp /tmp/starship-render.toml ~/.config/starship/matugen-rainbow.toml
        echo ":: [posthook] Updated ~/.config/starship/matugen-rainbow.toml defensively"
    fi
fi

# Keep the legacy root waybar/colors.css in sync with the matugen one,
# but only when not in an explicit "no matugen / transparent" mode.
if [ -f ~/.cache/matugen/no-matugen-this-time ] || [ -f ~/.cache/matugen/waybar-transparent-bright ] || [ -f ~/.cache/matugen/waybar-transparent-dark ] || [ -f ~/.cache/matugen/waybar-dark-text ] || [ -f ~/.cache/matugen/waybar-light-text ]; then
    echo "[posthook] Skipping waybar colors sync (None / transparent text mode active)"
else
    if [ -f ~/.config/waybar/colors/matugen.css ]; then
        cp -f ~/.config/waybar/colors/matugen.css ~/.config/waybar/colors.css 2>/dev/null || true
    fi
fi

# -----------------------------------------------------------------------------
# TTY (virtual console) palette - so Ctrl+Alt+F3 etc. match the current theme
# -----------------------------------------------------------------------------
"$HOME/.config/hypr/scripts/tty-theme.sh" 2>/dev/null || true &

# -----------------------------------------------------------------------------
# Plymouth splash theme (if installed and configured)
# This is backgrounded because it may need to elevate for /usr/share
# -----------------------------------------------------------------------------
"$HOME/.config/hypr/scripts/update-plymouth-theme.sh" 2>/dev/null || true &

echo "Matugen post-hook completed for: $(basename "$WALLPAPER" 2>/dev/null || echo "$WALLPAPER")"
