#!/bin/bash

# ━┏┛┃ ┃┏━┛┏┏ ┏━┛  ┏━┛┃┃┃┛━┏┛┏━┛┃ ┃┏━┛┏━┃
#  ┃ ┏━┃┏━┛┃┃┃┏━┛  ━━┃┃┃┃┃ ┃ ┃  ┏━┃┏━┛┏┏┛
#  ┛ ┛ ┛━━┛┛┛┛━━┛  ━━┛━━┛┛ ┛ ━━┛┛ ┛━━┛┛ ┛

# Check if the user provided an argument
if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <path_to_image>"
    exit 1
fi

IMAGE="$1"

# Send notification to the user
notify-send "Changing Theme" "Applying new wallpaper and updating colors, please wait until confirmation..."

# Set wallpaper (awww — see ~/.config/settings/wallpaper-engine.sh)
if command -v awww >/dev/null 2>&1; then
    awww img "$IMAGE" >/dev/null 2>&1 || true
fi

# Generate pywal colors
wal -i "$IMAGE" -n -s -t -e

# Refresh Spotify
#pywal-spicetify Dribbblish

# Use Matugen to generate Material You colors
matugen image "$IMAGE"

# Refresh waybar
pkill waybar
$HOME/.config/hyprgruv/scripts/launch.sh >/dev/null 2>&1 &

# Refresh SwayNC
"$HOME/.config/hyprgruv/scripts/matugen-posthook-swaync.sh" 2>/dev/null || true

notify-send "Theme Applied" "Wallpaper and theme updated successfully!"
