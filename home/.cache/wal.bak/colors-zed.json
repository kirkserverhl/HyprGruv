{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#10101990",
                "editor.background": "#10101990",
                "editor.foreground": "#c3c3c5",
                "text": "#c3c3c5",
                "text.muted": "#c3c3c570",
                "text.ignored": "#c3c3c540",
                "text.placeholder": "#c3c3c550",
                "ignored": "#c3c3c530",
                "element.hover": "#c3c3c530",
                "ghost_element.hover": "#887B9130",
                "ghost_element.selected": "#887B9130",
                "ghost_element.active": "#887B9160",
                "border": "#101019",
                "editor.highlighted_line.background": "#887B9110",
                "editor.active_line.background": "#887B9110",
                "panel.background": "#10101990",
                "title_bar.background": "#10101990",
                "title_bar.inactive_background": "#10101990",
                "status_bar.background": "#10101990",
                "drop_target.background": "#10101990",
                "elevated_surface.background": "#101019",
                "toolbar.background": "#10101990",
                "tab_bar.background": "#10101990",
                "tab.inactive_background": "#10101990",
                "tab.active_background": "#887B9130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#101019",
                "scrollbar.thumb.background": "#887B91",
                "editor.gutter.background": "#10101990",
                "terminal.background": "#10101910",
                "terminal.foreground": "#c3c3c5",
                "terminal.dim_foreground": "#c3c3c5",
                "terminal.bright_foreground": "#c3c3c5",
                "terminal.ansi.black": "#101019",
                "terminal.ansi.red": "#887B91",
                "terminal.ansi.green": "#A594AA",
                "terminal.ansi.yellow": "#D5A6B4",
                "terminal.ansi.blue": "#E7B4B2",
                "terminal.ansi.magenta": "#EAC6BA",
                "terminal.ansi.cyan": "#DABAC1",
                "terminal.ansi.white": "#c3c3c5",
                "terminal.ansi.bright_black": "#5b5b70",
                "terminal.ansi.bright_red": "#887B91",
                "terminal.ansi.bright_green": "#A594AA",
                "terminal.ansi.bright_yellow": "#D5A6B4",
                "terminal.ansi.bright_blue": "#E7B4B2",
                "terminal.ansi.bright_magenta": "#EAC6BA",
                "terminal.ansi.bright_cyan": "#DABAC1",
                "terminal.ansi.bright_white": "#c3c3c5",
                "modified": "#887B91",
                "syntax": {
                    "attribute": {
                        "color": "#887B91"
                    },
                    "boolean": {
                      "color": "#A594AA"
                    },
                    "comment": {
                      "color": "#5b5b70"
                    },
                    "comment.doc": {
                      "color": "#5b5b70"
                    },
                    "constant": {
                      "color": "#A594AA"
                    },
                    "function": {
                      "color": "#DABAC1"
                    },
                    "keyword": {
                      "color": "#E7B4B2"
                    },
                    "number": {
                      "color": "#EAC6BA"
                    },
                    "operator": {
                      "color": "#E7B4B2"
                    },
                    "string": {
                      "color": "#887B91"
                    },
                    "variable": {
                      "color": "#A594AA"
                    }
                },
                "players": [
                  {
                    "cursor": "#887B91",
                    "background": "#101019",
                    "selection": "#887B9130"
                  }
                ]
            }
        }
    ]
}
