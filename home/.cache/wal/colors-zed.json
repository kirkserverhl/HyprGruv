{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0f122390",
                "editor.background": "#0f122390",
                "editor.foreground": "#c3c3c8",
                "text": "#c3c3c8",
                "text.muted": "#c3c3c870",
                "text.ignored": "#c3c3c840",
                "text.placeholder": "#c3c3c850",
                "ignored": "#c3c3c830",
                "element.hover": "#c3c3c830",
                "ghost_element.hover": "#7B859E30",
                "ghost_element.selected": "#7B859E30",
                "ghost_element.active": "#7B859E60",
                "border": "#0f1223",
                "editor.highlighted_line.background": "#7B859E10",
                "editor.active_line.background": "#7B859E10",
                "panel.background": "#0f122390",
                "title_bar.background": "#0f122390",
                "title_bar.inactive_background": "#0f122390",
                "status_bar.background": "#0f122390",
                "drop_target.background": "#0f122390",
                "elevated_surface.background": "#0f1223",
                "toolbar.background": "#0f122390",
                "tab_bar.background": "#0f122390",
                "tab.inactive_background": "#0f122390",
                "tab.active_background": "#7B859E30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0f1223",
                "scrollbar.thumb.background": "#7B859E",
                "editor.gutter.background": "#0f122390",
                "terminal.background": "#0f122310",
                "terminal.foreground": "#c3c3c8",
                "terminal.dim_foreground": "#c3c3c8",
                "terminal.bright_foreground": "#c3c3c8",
                "terminal.ansi.black": "#0f1223",
                "terminal.ansi.red": "#7B859E",
                "terminal.ansi.green": "#8B93AD",
                "terminal.ansi.yellow": "#DBAAAF",
                "terminal.ansi.blue": "#8B9FC1",
                "terminal.ansi.magenta": "#8EAED6",
                "terminal.ansi.cyan": "#8FBCE5",
                "terminal.ansi.white": "#c3c3c8",
                "terminal.ansi.bright_black": "#5e6074",
                "terminal.ansi.bright_red": "#7B859E",
                "terminal.ansi.bright_green": "#8B93AD",
                "terminal.ansi.bright_yellow": "#DBAAAF",
                "terminal.ansi.bright_blue": "#8B9FC1",
                "terminal.ansi.bright_magenta": "#8EAED6",
                "terminal.ansi.bright_cyan": "#8FBCE5",
                "terminal.ansi.bright_white": "#c3c3c8",
                "modified": "#7B859E",
                "syntax": {
                    "attribute": {
                        "color": "#7B859E"
                    },
                    "boolean": {
                      "color": "#8B93AD"
                    },
                    "comment": {
                      "color": "#5e6074"
                    },
                    "comment.doc": {
                      "color": "#5e6074"
                    },
                    "constant": {
                      "color": "#8B93AD"
                    },
                    "function": {
                      "color": "#8FBCE5"
                    },
                    "keyword": {
                      "color": "#8B9FC1"
                    },
                    "number": {
                      "color": "#8EAED6"
                    },
                    "operator": {
                      "color": "#8B9FC1"
                    },
                    "string": {
                      "color": "#7B859E"
                    },
                    "variable": {
                      "color": "#8B93AD"
                    }
                },
                "players": [
                  {
                    "cursor": "#7B859E",
                    "background": "#0f1223",
                    "selection": "#7B859E30"
                  }
                ]
            }
        }
    ]
}
