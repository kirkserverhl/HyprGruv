{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#10111990",
                "editor.background": "#10111990",
                "editor.foreground": "#c3c3c5",
                "text": "#c3c3c5",
                "text.muted": "#c3c3c570",
                "text.ignored": "#c3c3c540",
                "text.placeholder": "#c3c3c550",
                "ignored": "#c3c3c530",
                "element.hover": "#c3c3c530",
                "ghost_element.hover": "#5E6A8330",
                "ghost_element.selected": "#5E6A8330",
                "ghost_element.active": "#5E6A8360",
                "border": "#101119",
                "editor.highlighted_line.background": "#5E6A8310",
                "editor.active_line.background": "#5E6A8310",
                "panel.background": "#10111990",
                "title_bar.background": "#10111990",
                "title_bar.inactive_background": "#10111990",
                "status_bar.background": "#10111990",
                "drop_target.background": "#10111990",
                "elevated_surface.background": "#101119",
                "toolbar.background": "#10111990",
                "tab_bar.background": "#10111990",
                "tab.inactive_background": "#10111990",
                "tab.active_background": "#5E6A8330",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#101119",
                "scrollbar.thumb.background": "#5E6A83",
                "editor.gutter.background": "#10111990",
                "terminal.background": "#10111910",
                "terminal.foreground": "#c3c3c5",
                "terminal.dim_foreground": "#c3c3c5",
                "terminal.bright_foreground": "#c3c3c5",
                "terminal.ansi.black": "#101119",
                "terminal.ansi.red": "#5E6A83",
                "terminal.ansi.green": "#71748A",
                "terminal.ansi.yellow": "#887A8E",
                "terminal.ansi.blue": "#7B849C",
                "terminal.ansi.magenta": "#9793AA",
                "terminal.ansi.cyan": "#ACAECF",
                "terminal.ansi.white": "#c3c3c5",
                "terminal.ansi.bright_black": "#5b5f70",
                "terminal.ansi.bright_red": "#5E6A83",
                "terminal.ansi.bright_green": "#71748A",
                "terminal.ansi.bright_yellow": "#887A8E",
                "terminal.ansi.bright_blue": "#7B849C",
                "terminal.ansi.bright_magenta": "#9793AA",
                "terminal.ansi.bright_cyan": "#ACAECF",
                "terminal.ansi.bright_white": "#c3c3c5",
                "modified": "#5E6A83",
                "syntax": {
                    "attribute": {
                        "color": "#5E6A83"
                    },
                    "boolean": {
                      "color": "#71748A"
                    },
                    "comment": {
                      "color": "#5b5f70"
                    },
                    "comment.doc": {
                      "color": "#5b5f70"
                    },
                    "constant": {
                      "color": "#71748A"
                    },
                    "function": {
                      "color": "#ACAECF"
                    },
                    "keyword": {
                      "color": "#7B849C"
                    },
                    "number": {
                      "color": "#9793AA"
                    },
                    "operator": {
                      "color": "#7B849C"
                    },
                    "string": {
                      "color": "#5E6A83"
                    },
                    "variable": {
                      "color": "#71748A"
                    }
                },
                "players": [
                  {
                    "cursor": "#5E6A83",
                    "background": "#101119",
                    "selection": "#5E6A8330"
                  }
                ]
            }
        }
    ]
}
