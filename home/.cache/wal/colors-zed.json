{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#10121390",
                "editor.background": "#10121390",
                "editor.foreground": "#c3c3c4",
                "text": "#c3c3c4",
                "text.muted": "#c3c3c470",
                "text.ignored": "#c3c3c440",
                "text.placeholder": "#c3c3c450",
                "ignored": "#c3c3c430",
                "element.hover": "#c3c3c430",
                "ghost_element.hover": "#D58A7530",
                "ghost_element.selected": "#D58A7530",
                "ghost_element.active": "#D58A7560",
                "border": "#101213",
                "editor.highlighted_line.background": "#D58A7510",
                "editor.active_line.background": "#D58A7510",
                "panel.background": "#10121390",
                "title_bar.background": "#10121390",
                "title_bar.inactive_background": "#10121390",
                "status_bar.background": "#10121390",
                "drop_target.background": "#10121390",
                "elevated_surface.background": "#101213",
                "toolbar.background": "#10121390",
                "tab_bar.background": "#10121390",
                "tab.inactive_background": "#10121390",
                "tab.active_background": "#D58A7530",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#101213",
                "scrollbar.thumb.background": "#D58A75",
                "editor.gutter.background": "#10121390",
                "terminal.background": "#10121310",
                "terminal.foreground": "#c3c3c4",
                "terminal.dim_foreground": "#c3c3c4",
                "terminal.bright_foreground": "#c3c3c4",
                "terminal.ansi.black": "#101213",
                "terminal.ansi.red": "#D58A75",
                "terminal.ansi.green": "#749190",
                "terminal.ansi.yellow": "#7B9E95",
                "terminal.ansi.blue": "#879893",
                "terminal.ansi.magenta": "#8CA799",
                "terminal.ansi.cyan": "#AEA098",
                "terminal.ansi.white": "#c3c3c4",
                "terminal.ansi.bright_black": "#59636e",
                "terminal.ansi.bright_red": "#D58A75",
                "terminal.ansi.bright_green": "#749190",
                "terminal.ansi.bright_yellow": "#7B9E95",
                "terminal.ansi.bright_blue": "#879893",
                "terminal.ansi.bright_magenta": "#8CA799",
                "terminal.ansi.bright_cyan": "#AEA098",
                "terminal.ansi.bright_white": "#c3c3c4",
                "modified": "#D58A75",
                "syntax": {
                    "attribute": {
                        "color": "#D58A75"
                    },
                    "boolean": {
                      "color": "#749190"
                    },
                    "comment": {
                      "color": "#59636e"
                    },
                    "comment.doc": {
                      "color": "#59636e"
                    },
                    "constant": {
                      "color": "#749190"
                    },
                    "function": {
                      "color": "#AEA098"
                    },
                    "keyword": {
                      "color": "#879893"
                    },
                    "number": {
                      "color": "#8CA799"
                    },
                    "operator": {
                      "color": "#879893"
                    },
                    "string": {
                      "color": "#D58A75"
                    },
                    "variable": {
                      "color": "#749190"
                    }
                },
                "players": [
                  {
                    "cursor": "#D58A75",
                    "background": "#101213",
                    "selection": "#D58A7530"
                  }
                ]
            }
        }
    ]
}
