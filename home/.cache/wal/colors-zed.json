{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1b1e2590",
                "editor.background": "#1b1e2590",
                "editor.foreground": "#c6c6c8",
                "text": "#c6c6c8",
                "text.muted": "#c6c6c870",
                "text.ignored": "#c6c6c840",
                "text.placeholder": "#c6c6c850",
                "ignored": "#c6c6c830",
                "element.hover": "#c6c6c830",
                "ghost_element.hover": "#637A8630",
                "ghost_element.selected": "#637A8630",
                "ghost_element.active": "#637A8660",
                "border": "#1b1e25",
                "editor.highlighted_line.background": "#637A8610",
                "editor.active_line.background": "#637A8610",
                "panel.background": "#1b1e2590",
                "title_bar.background": "#1b1e2590",
                "title_bar.inactive_background": "#1b1e2590",
                "status_bar.background": "#1b1e2590",
                "drop_target.background": "#1b1e2590",
                "elevated_surface.background": "#1b1e25",
                "toolbar.background": "#1b1e2590",
                "tab_bar.background": "#1b1e2590",
                "tab.inactive_background": "#1b1e2590",
                "tab.active_background": "#637A8630",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1b1e25",
                "scrollbar.thumb.background": "#637A86",
                "editor.gutter.background": "#1b1e2590",
                "terminal.background": "#1b1e2510",
                "terminal.foreground": "#c6c6c8",
                "terminal.dim_foreground": "#c6c6c8",
                "terminal.bright_foreground": "#c6c6c8",
                "terminal.ansi.black": "#1b1e25",
                "terminal.ansi.red": "#637A86",
                "terminal.ansi.green": "#6E8A93",
                "terminal.ansi.yellow": "#7A9CA2",
                "terminal.ansi.blue": "#7EA2A6",
                "terminal.ansi.magenta": "#8FBBBB",
                "terminal.ansi.cyan": "#92C0BE",
                "terminal.ansi.white": "#c6c6c8",
                "terminal.ansi.bright_black": "#626878",
                "terminal.ansi.bright_red": "#637A86",
                "terminal.ansi.bright_green": "#6E8A93",
                "terminal.ansi.bright_yellow": "#7A9CA2",
                "terminal.ansi.bright_blue": "#7EA2A6",
                "terminal.ansi.bright_magenta": "#8FBBBB",
                "terminal.ansi.bright_cyan": "#92C0BE",
                "terminal.ansi.bright_white": "#c6c6c8",
                "modified": "#637A86",
                "syntax": {
                    "attribute": {
                        "color": "#637A86"
                    },
                    "boolean": {
                      "color": "#6E8A93"
                    },
                    "comment": {
                      "color": "#626878"
                    },
                    "comment.doc": {
                      "color": "#626878"
                    },
                    "constant": {
                      "color": "#6E8A93"
                    },
                    "function": {
                      "color": "#92C0BE"
                    },
                    "keyword": {
                      "color": "#7EA2A6"
                    },
                    "number": {
                      "color": "#8FBBBB"
                    },
                    "operator": {
                      "color": "#7EA2A6"
                    },
                    "string": {
                      "color": "#637A86"
                    },
                    "variable": {
                      "color": "#6E8A93"
                    }
                },
                "players": [
                  {
                    "cursor": "#637A86",
                    "background": "#1b1e25",
                    "selection": "#637A8630"
                  }
                ]
            }
        }
    ]
}
