{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#18181890",
                "editor.background": "#18181890",
                "editor.foreground": "#c5c5c5",
                "text": "#c5c5c5",
                "text.muted": "#c5c5c570",
                "text.ignored": "#c5c5c540",
                "text.placeholder": "#c5c5c550",
                "ignored": "#c5c5c530",
                "element.hover": "#c5c5c530",
                "ghost_element.hover": "#5F6C6630",
                "ghost_element.selected": "#5F6C6630",
                "ghost_element.active": "#5F6C6660",
                "border": "#181818",
                "editor.highlighted_line.background": "#5F6C6610",
                "editor.active_line.background": "#5F6C6610",
                "panel.background": "#18181890",
                "title_bar.background": "#18181890",
                "title_bar.inactive_background": "#18181890",
                "status_bar.background": "#18181890",
                "drop_target.background": "#18181890",
                "elevated_surface.background": "#181818",
                "toolbar.background": "#18181890",
                "tab_bar.background": "#18181890",
                "tab.inactive_background": "#18181890",
                "tab.active_background": "#5F6C6630",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#181818",
                "scrollbar.thumb.background": "#5F6C66",
                "editor.gutter.background": "#18181890",
                "terminal.background": "#18181810",
                "terminal.foreground": "#c5c5c5",
                "terminal.dim_foreground": "#c5c5c5",
                "terminal.bright_foreground": "#c5c5c5",
                "terminal.ansi.black": "#181818",
                "terminal.ansi.red": "#5F6C66",
                "terminal.ansi.green": "#757C74",
                "terminal.ansi.yellow": "#6A8279",
                "terminal.ansi.blue": "#928475",
                "terminal.ansi.magenta": "#3F8684",
                "terminal.ansi.cyan": "#67928C",
                "terminal.ansi.white": "#c5c5c5",
                "terminal.ansi.bright_black": "#725d5d",
                "terminal.ansi.bright_red": "#5F6C66",
                "terminal.ansi.bright_green": "#757C74",
                "terminal.ansi.bright_yellow": "#6A8279",
                "terminal.ansi.bright_blue": "#928475",
                "terminal.ansi.bright_magenta": "#3F8684",
                "terminal.ansi.bright_cyan": "#67928C",
                "terminal.ansi.bright_white": "#c5c5c5",
                "modified": "#5F6C66",
                "syntax": {
                    "attribute": {
                        "color": "#5F6C66"
                    },
                    "boolean": {
                      "color": "#757C74"
                    },
                    "comment": {
                      "color": "#725d5d"
                    },
                    "comment.doc": {
                      "color": "#725d5d"
                    },
                    "constant": {
                      "color": "#757C74"
                    },
                    "function": {
                      "color": "#67928C"
                    },
                    "keyword": {
                      "color": "#928475"
                    },
                    "number": {
                      "color": "#3F8684"
                    },
                    "operator": {
                      "color": "#928475"
                    },
                    "string": {
                      "color": "#5F6C66"
                    },
                    "variable": {
                      "color": "#757C74"
                    }
                },
                "players": [
                  {
                    "cursor": "#5F6C66",
                    "background": "#181818",
                    "selection": "#5F6C6630"
                  }
                ]
            }
        }
    ]
}
