{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#12111390",
                "editor.background": "#12111390",
                "editor.foreground": "#c3c3c4",
                "text": "#c3c3c4",
                "text.muted": "#c3c3c470",
                "text.ignored": "#c3c3c440",
                "text.placeholder": "#c3c3c450",
                "ignored": "#c3c3c430",
                "element.hover": "#c3c3c430",
                "ghost_element.hover": "#8D615930",
                "ghost_element.selected": "#8D615930",
                "ghost_element.active": "#8D615960",
                "border": "#121113",
                "editor.highlighted_line.background": "#8D615910",
                "editor.active_line.background": "#8D615910",
                "panel.background": "#12111390",
                "title_bar.background": "#12111390",
                "title_bar.inactive_background": "#12111390",
                "status_bar.background": "#12111390",
                "drop_target.background": "#12111390",
                "elevated_surface.background": "#121113",
                "toolbar.background": "#12111390",
                "tab_bar.background": "#12111390",
                "tab.inactive_background": "#12111390",
                "tab.active_background": "#8D615930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#121113",
                "scrollbar.thumb.background": "#8D6159",
                "editor.gutter.background": "#12111390",
                "terminal.background": "#12111310",
                "terminal.foreground": "#c3c3c4",
                "terminal.dim_foreground": "#c3c3c4",
                "terminal.bright_foreground": "#c3c3c4",
                "terminal.ansi.black": "#121113",
                "terminal.ansi.red": "#8D6159",
                "terminal.ansi.green": "#B8685A",
                "terminal.ansi.yellow": "#8E716C",
                "terminal.ansi.blue": "#AA8778",
                "terminal.ansi.magenta": "#867E82",
                "terminal.ansi.cyan": "#A99993",
                "terminal.ansi.white": "#c3c3c4",
                "terminal.ansi.bright_black": "#5a5a6e",
                "terminal.ansi.bright_red": "#8D6159",
                "terminal.ansi.bright_green": "#B8685A",
                "terminal.ansi.bright_yellow": "#8E716C",
                "terminal.ansi.bright_blue": "#AA8778",
                "terminal.ansi.bright_magenta": "#867E82",
                "terminal.ansi.bright_cyan": "#A99993",
                "terminal.ansi.bright_white": "#c3c3c4",
                "modified": "#8D6159",
                "syntax": {
                    "attribute": {
                        "color": "#8D6159"
                    },
                    "boolean": {
                      "color": "#B8685A"
                    },
                    "comment": {
                      "color": "#5a5a6e"
                    },
                    "comment.doc": {
                      "color": "#5a5a6e"
                    },
                    "constant": {
                      "color": "#B8685A"
                    },
                    "function": {
                      "color": "#A99993"
                    },
                    "keyword": {
                      "color": "#AA8778"
                    },
                    "number": {
                      "color": "#867E82"
                    },
                    "operator": {
                      "color": "#AA8778"
                    },
                    "string": {
                      "color": "#8D6159"
                    },
                    "variable": {
                      "color": "#B8685A"
                    }
                },
                "players": [
                  {
                    "cursor": "#8D6159",
                    "background": "#121113",
                    "selection": "#8D615930"
                  }
                ]
            }
        }
    ]
}
