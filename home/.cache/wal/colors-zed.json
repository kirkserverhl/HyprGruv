{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d201090",
                "editor.background": "#0d201090",
                "editor.foreground": "#c2c7c3",
                "text": "#c2c7c3",
                "text.muted": "#c2c7c370",
                "text.ignored": "#c2c7c340",
                "text.placeholder": "#c2c7c350",
                "ignored": "#c2c7c330",
                "element.hover": "#c2c7c330",
                "ghost_element.hover": "#B7917130",
                "ghost_element.selected": "#B7917130",
                "ghost_element.active": "#B7917160",
                "border": "#0d2010",
                "editor.highlighted_line.background": "#B7917110",
                "editor.active_line.background": "#B7917110",
                "panel.background": "#0d201090",
                "title_bar.background": "#0d201090",
                "title_bar.inactive_background": "#0d201090",
                "status_bar.background": "#0d201090",
                "drop_target.background": "#0d201090",
                "elevated_surface.background": "#0d2010",
                "toolbar.background": "#0d201090",
                "tab_bar.background": "#0d201090",
                "tab.inactive_background": "#0d201090",
                "tab.active_background": "#B7917130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d2010",
                "scrollbar.thumb.background": "#B79171",
                "editor.gutter.background": "#0d201090",
                "terminal.background": "#0d201010",
                "terminal.foreground": "#c2c7c3",
                "terminal.dim_foreground": "#c2c7c3",
                "terminal.bright_foreground": "#c2c7c3",
                "terminal.ansi.black": "#0d2010",
                "terminal.ansi.red": "#B79171",
                "terminal.ansi.green": "#40778B",
                "terminal.ansi.yellow": "#767F80",
                "terminal.ansi.blue": "#2CAAB1",
                "terminal.ansi.magenta": "#669495",
                "terminal.ansi.cyan": "#98A1A0",
                "terminal.ansi.white": "#c2c7c3",
                "terminal.ansi.bright_black": "#5d7160",
                "terminal.ansi.bright_red": "#B79171",
                "terminal.ansi.bright_green": "#40778B",
                "terminal.ansi.bright_yellow": "#767F80",
                "terminal.ansi.bright_blue": "#2CAAB1",
                "terminal.ansi.bright_magenta": "#669495",
                "terminal.ansi.bright_cyan": "#98A1A0",
                "terminal.ansi.bright_white": "#c2c7c3",
                "modified": "#B79171",
                "syntax": {
                    "attribute": {
                        "color": "#B79171"
                    },
                    "boolean": {
                      "color": "#40778B"
                    },
                    "comment": {
                      "color": "#5d7160"
                    },
                    "comment.doc": {
                      "color": "#5d7160"
                    },
                    "constant": {
                      "color": "#40778B"
                    },
                    "function": {
                      "color": "#98A1A0"
                    },
                    "keyword": {
                      "color": "#2CAAB1"
                    },
                    "number": {
                      "color": "#669495"
                    },
                    "operator": {
                      "color": "#2CAAB1"
                    },
                    "string": {
                      "color": "#B79171"
                    },
                    "variable": {
                      "color": "#40778B"
                    }
                },
                "players": [
                  {
                    "cursor": "#B79171",
                    "background": "#0d2010",
                    "selection": "#B7917130"
                  }
                ]
            }
        }
    ]
}
