{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0b141990",
                "editor.background": "#0b141990",
                "editor.foreground": "#c2c4c5",
                "text": "#c2c4c5",
                "text.muted": "#c2c4c570",
                "text.ignored": "#c2c4c540",
                "text.placeholder": "#c2c4c550",
                "ignored": "#c2c4c530",
                "element.hover": "#c2c4c530",
                "ghost_element.hover": "#80807130",
                "ghost_element.selected": "#80807130",
                "ghost_element.active": "#80807160",
                "border": "#0b1419",
                "editor.highlighted_line.background": "#80807110",
                "editor.active_line.background": "#80807110",
                "panel.background": "#0b141990",
                "title_bar.background": "#0b141990",
                "title_bar.inactive_background": "#0b141990",
                "status_bar.background": "#0b141990",
                "drop_target.background": "#0b141990",
                "elevated_surface.background": "#0b1419",
                "toolbar.background": "#0b141990",
                "tab_bar.background": "#0b141990",
                "tab.inactive_background": "#0b141990",
                "tab.active_background": "#80807130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0b1419",
                "scrollbar.thumb.background": "#808071",
                "editor.gutter.background": "#0b141990",
                "terminal.background": "#0b141910",
                "terminal.foreground": "#c2c4c5",
                "terminal.dim_foreground": "#c2c4c5",
                "terminal.bright_foreground": "#c2c4c5",
                "terminal.ansi.black": "#0b1419",
                "terminal.ansi.red": "#808071",
                "terminal.ansi.green": "#898979",
                "terminal.ansi.yellow": "#A7A794",
                "terminal.ansi.blue": "#C1BEA9",
                "terminal.ansi.magenta": "#CECCB5",
                "terminal.ansi.cyan": "#DDDBC4",
                "terminal.ansi.white": "#c2c4c5",
                "terminal.ansi.bright_black": "#5a676e",
                "terminal.ansi.bright_red": "#808071",
                "terminal.ansi.bright_green": "#898979",
                "terminal.ansi.bright_yellow": "#A7A794",
                "terminal.ansi.bright_blue": "#C1BEA9",
                "terminal.ansi.bright_magenta": "#CECCB5",
                "terminal.ansi.bright_cyan": "#DDDBC4",
                "terminal.ansi.bright_white": "#c2c4c5",
                "modified": "#808071",
                "syntax": {
                    "attribute": {
                        "color": "#808071"
                    },
                    "boolean": {
                      "color": "#898979"
                    },
                    "comment": {
                      "color": "#5a676e"
                    },
                    "comment.doc": {
                      "color": "#5a676e"
                    },
                    "constant": {
                      "color": "#898979"
                    },
                    "function": {
                      "color": "#DDDBC4"
                    },
                    "keyword": {
                      "color": "#C1BEA9"
                    },
                    "number": {
                      "color": "#CECCB5"
                    },
                    "operator": {
                      "color": "#C1BEA9"
                    },
                    "string": {
                      "color": "#808071"
                    },
                    "variable": {
                      "color": "#898979"
                    }
                },
                "players": [
                  {
                    "cursor": "#808071",
                    "background": "#0b1419",
                    "selection": "#80807130"
                  }
                ]
            }
        }
    ]
}
