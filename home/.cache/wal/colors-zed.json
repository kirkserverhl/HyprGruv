{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#1a0b0b90",
                "editor.background": "#1a0b0b90",
                "editor.foreground": "#c5c2c2",
                "text": "#c5c2c2",
                "text.muted": "#c5c2c270",
                "text.ignored": "#c5c2c240",
                "text.placeholder": "#c5c2c250",
                "ignored": "#c5c2c230",
                "element.hover": "#c5c2c230",
                "ghost_element.hover": "#38436730",
                "ghost_element.selected": "#38436730",
                "ghost_element.active": "#38436760",
                "border": "#1a0b0b",
                "editor.highlighted_line.background": "#38436710",
                "editor.active_line.background": "#38436710",
                "panel.background": "#1a0b0b90",
                "title_bar.background": "#1a0b0b90",
                "title_bar.inactive_background": "#1a0b0b90",
                "status_bar.background": "#1a0b0b90",
                "drop_target.background": "#1a0b0b90",
                "elevated_surface.background": "#1a0b0b",
                "toolbar.background": "#1a0b0b90",
                "tab_bar.background": "#1a0b0b90",
                "tab.inactive_background": "#1a0b0b90",
                "tab.active_background": "#38436730",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#1a0b0b",
                "scrollbar.thumb.background": "#384367",
                "editor.gutter.background": "#1a0b0b90",
                "terminal.background": "#1a0b0b10",
                "terminal.foreground": "#c5c2c2",
                "terminal.dim_foreground": "#c5c2c2",
                "terminal.bright_foreground": "#c5c2c2",
                "terminal.ansi.black": "#1a0b0b",
                "terminal.ansi.red": "#384367",
                "terminal.ansi.green": "#4A4F50",
                "terminal.ansi.yellow": "#62696C",
                "terminal.ansi.blue": "#6A6F8E",
                "terminal.ansi.magenta": "#817D9A",
                "terminal.ansi.cyan": "#78868C",
                "terminal.ansi.white": "#c5c2c2",
                "terminal.ansi.bright_black": "#6f5a5a",
                "terminal.ansi.bright_red": "#384367",
                "terminal.ansi.bright_green": "#4A4F50",
                "terminal.ansi.bright_yellow": "#62696C",
                "terminal.ansi.bright_blue": "#6A6F8E",
                "terminal.ansi.bright_magenta": "#817D9A",
                "terminal.ansi.bright_cyan": "#78868C",
                "terminal.ansi.bright_white": "#c5c2c2",
                "modified": "#384367",
                "syntax": {
                    "attribute": {
                        "color": "#384367"
                    },
                    "boolean": {
                      "color": "#4A4F50"
                    },
                    "comment": {
                      "color": "#6f5a5a"
                    },
                    "comment.doc": {
                      "color": "#6f5a5a"
                    },
                    "constant": {
                      "color": "#4A4F50"
                    },
                    "function": {
                      "color": "#78868C"
                    },
                    "keyword": {
                      "color": "#6A6F8E"
                    },
                    "number": {
                      "color": "#817D9A"
                    },
                    "operator": {
                      "color": "#6A6F8E"
                    },
                    "string": {
                      "color": "#384367"
                    },
                    "variable": {
                      "color": "#4A4F50"
                    }
                },
                "players": [
                  {
                    "cursor": "#384367",
                    "background": "#1a0b0b",
                    "selection": "#38436730"
                  }
                ]
            }
        }
    ]
}
