{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0f122490",
                "editor.background": "#0f122490",
                "editor.foreground": "#c3c3c8",
                "text": "#c3c3c8",
                "text.muted": "#c3c3c870",
                "text.ignored": "#c3c3c840",
                "text.placeholder": "#c3c3c850",
                "ignored": "#c3c3c830",
                "element.hover": "#c3c3c830",
                "ghost_element.hover": "#5E617530",
                "ghost_element.selected": "#5E617530",
                "ghost_element.active": "#5E617560",
                "border": "#0f1224",
                "editor.highlighted_line.background": "#5E617510",
                "editor.active_line.background": "#5E617510",
                "panel.background": "#0f122490",
                "title_bar.background": "#0f122490",
                "title_bar.inactive_background": "#0f122490",
                "status_bar.background": "#0f122490",
                "drop_target.background": "#0f122490",
                "elevated_surface.background": "#0f1224",
                "toolbar.background": "#0f122490",
                "tab_bar.background": "#0f122490",
                "tab.inactive_background": "#0f122490",
                "tab.active_background": "#5E617530",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0f1224",
                "scrollbar.thumb.background": "#5E6175",
                "editor.gutter.background": "#0f122490",
                "terminal.background": "#0f122410",
                "terminal.foreground": "#c3c3c8",
                "terminal.dim_foreground": "#c3c3c8",
                "terminal.bright_foreground": "#c3c3c8",
                "terminal.ansi.black": "#0f1224",
                "terminal.ansi.red": "#5E6175",
                "terminal.ansi.green": "#64677B",
                "terminal.ansi.yellow": "#717489",
                "terminal.ansi.blue": "#7E7E94",
                "terminal.ansi.magenta": "#8A7B8F",
                "terminal.ansi.cyan": "#9F8DA2",
                "terminal.ansi.white": "#c3c3c8",
                "terminal.ansi.bright_black": "#5e6074",
                "terminal.ansi.bright_red": "#5E6175",
                "terminal.ansi.bright_green": "#64677B",
                "terminal.ansi.bright_yellow": "#717489",
                "terminal.ansi.bright_blue": "#7E7E94",
                "terminal.ansi.bright_magenta": "#8A7B8F",
                "terminal.ansi.bright_cyan": "#9F8DA2",
                "terminal.ansi.bright_white": "#c3c3c8",
                "modified": "#5E6175",
                "syntax": {
                    "attribute": {
                        "color": "#5E6175"
                    },
                    "boolean": {
                      "color": "#64677B"
                    },
                    "comment": {
                      "color": "#5e6074"
                    },
                    "comment.doc": {
                      "color": "#5e6074"
                    },
                    "constant": {
                      "color": "#64677B"
                    },
                    "function": {
                      "color": "#9F8DA2"
                    },
                    "keyword": {
                      "color": "#7E7E94"
                    },
                    "number": {
                      "color": "#8A7B8F"
                    },
                    "operator": {
                      "color": "#7E7E94"
                    },
                    "string": {
                      "color": "#5E6175"
                    },
                    "variable": {
                      "color": "#64677B"
                    }
                },
                "players": [
                  {
                    "cursor": "#5E6175",
                    "background": "#0f1224",
                    "selection": "#5E617530"
                  }
                ]
            }
        }
    ]
}
