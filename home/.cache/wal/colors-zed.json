{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a101890",
                "editor.background": "#0a101890",
                "editor.foreground": "#c1c3c5",
                "text": "#c1c3c5",
                "text.muted": "#c1c3c570",
                "text.ignored": "#c1c3c540",
                "text.placeholder": "#c1c3c550",
                "ignored": "#c1c3c530",
                "element.hover": "#c1c3c530",
                "ghost_element.hover": "#837C7830",
                "ghost_element.selected": "#837C7830",
                "ghost_element.active": "#837C7860",
                "border": "#0a1018",
                "editor.highlighted_line.background": "#837C7810",
                "editor.active_line.background": "#837C7810",
                "panel.background": "#0a101890",
                "title_bar.background": "#0a101890",
                "title_bar.inactive_background": "#0a101890",
                "status_bar.background": "#0a101890",
                "drop_target.background": "#0a101890",
                "elevated_surface.background": "#0a1018",
                "toolbar.background": "#0a101890",
                "tab_bar.background": "#0a101890",
                "tab.inactive_background": "#0a101890",
                "tab.active_background": "#837C7830",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a1018",
                "scrollbar.thumb.background": "#837C78",
                "editor.gutter.background": "#0a101890",
                "terminal.background": "#0a101810",
                "terminal.foreground": "#c1c3c5",
                "terminal.dim_foreground": "#c1c3c5",
                "terminal.bright_foreground": "#c1c3c5",
                "terminal.ansi.black": "#0a1018",
                "terminal.ansi.red": "#837C78",
                "terminal.ansi.green": "#7C837E",
                "terminal.ansi.yellow": "#89827D",
                "terminal.ansi.blue": "#968F89",
                "terminal.ansi.magenta": "#A39C95",
                "terminal.ansi.cyan": "#AAA39C",
                "terminal.ansi.white": "#c1c3c5",
                "terminal.ansi.bright_black": "#59626d",
                "terminal.ansi.bright_red": "#837C78",
                "terminal.ansi.bright_green": "#7C837E",
                "terminal.ansi.bright_yellow": "#89827D",
                "terminal.ansi.bright_blue": "#968F89",
                "terminal.ansi.bright_magenta": "#A39C95",
                "terminal.ansi.bright_cyan": "#AAA39C",
                "terminal.ansi.bright_white": "#c1c3c5",
                "modified": "#837C78",
                "syntax": {
                    "attribute": {
                        "color": "#837C78"
                    },
                    "boolean": {
                      "color": "#7C837E"
                    },
                    "comment": {
                      "color": "#59626d"
                    },
                    "comment.doc": {
                      "color": "#59626d"
                    },
                    "constant": {
                      "color": "#7C837E"
                    },
                    "function": {
                      "color": "#AAA39C"
                    },
                    "keyword": {
                      "color": "#968F89"
                    },
                    "number": {
                      "color": "#A39C95"
                    },
                    "operator": {
                      "color": "#968F89"
                    },
                    "string": {
                      "color": "#837C78"
                    },
                    "variable": {
                      "color": "#7C837E"
                    }
                },
                "players": [
                  {
                    "cursor": "#837C78",
                    "background": "#0a1018",
                    "selection": "#837C7830"
                  }
                ]
            }
        }
    ]
}
