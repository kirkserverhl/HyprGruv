{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#16090990",
                "editor.background": "#16090990",
                "editor.foreground": "#c4c1c1",
                "text": "#c4c1c1",
                "text.muted": "#c4c1c170",
                "text.ignored": "#c4c1c140",
                "text.placeholder": "#c4c1c150",
                "ignored": "#c4c1c130",
                "element.hover": "#c4c1c130",
                "ghost_element.hover": "#4D4D4D30",
                "ghost_element.selected": "#4D4D4D30",
                "ghost_element.active": "#4D4D4D60",
                "border": "#160909",
                "editor.highlighted_line.background": "#4D4D4D10",
                "editor.active_line.background": "#4D4D4D10",
                "panel.background": "#16090990",
                "title_bar.background": "#16090990",
                "title_bar.inactive_background": "#16090990",
                "status_bar.background": "#16090990",
                "drop_target.background": "#16090990",
                "elevated_surface.background": "#160909",
                "toolbar.background": "#16090990",
                "tab_bar.background": "#16090990",
                "tab.inactive_background": "#16090990",
                "tab.active_background": "#4D4D4D30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#160909",
                "scrollbar.thumb.background": "#4D4D4D",
                "editor.gutter.background": "#16090990",
                "terminal.background": "#16090910",
                "terminal.foreground": "#c4c1c1",
                "terminal.dim_foreground": "#c4c1c1",
                "terminal.bright_foreground": "#c4c1c1",
                "terminal.ansi.black": "#160909",
                "terminal.ansi.red": "#4D4D4D",
                "terminal.ansi.green": "#605F60",
                "terminal.ansi.yellow": "#6E6E6E",
                "terminal.ansi.blue": "#8E8E8E",
                "terminal.ansi.magenta": "#A09FA0",
                "terminal.ansi.cyan": "#AEAEAE",
                "terminal.ansi.white": "#c4c1c1",
                "terminal.ansi.bright_black": "#6c5959",
                "terminal.ansi.bright_red": "#4D4D4D",
                "terminal.ansi.bright_green": "#605F60",
                "terminal.ansi.bright_yellow": "#6E6E6E",
                "terminal.ansi.bright_blue": "#8E8E8E",
                "terminal.ansi.bright_magenta": "#A09FA0",
                "terminal.ansi.bright_cyan": "#AEAEAE",
                "terminal.ansi.bright_white": "#c4c1c1",
                "modified": "#4D4D4D",
                "syntax": {
                    "attribute": {
                        "color": "#4D4D4D"
                    },
                    "boolean": {
                      "color": "#605F60"
                    },
                    "comment": {
                      "color": "#6c5959"
                    },
                    "comment.doc": {
                      "color": "#6c5959"
                    },
                    "constant": {
                      "color": "#605F60"
                    },
                    "function": {
                      "color": "#AEAEAE"
                    },
                    "keyword": {
                      "color": "#8E8E8E"
                    },
                    "number": {
                      "color": "#A09FA0"
                    },
                    "operator": {
                      "color": "#8E8E8E"
                    },
                    "string": {
                      "color": "#4D4D4D"
                    },
                    "variable": {
                      "color": "#605F60"
                    }
                },
                "players": [
                  {
                    "cursor": "#4D4D4D",
                    "background": "#160909",
                    "selection": "#4D4D4D30"
                  }
                ]
            }
        }
    ]
}
