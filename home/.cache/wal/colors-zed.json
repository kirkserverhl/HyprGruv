{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#12121290",
                "editor.background": "#12121290",
                "editor.foreground": "#c3c3c3",
                "text": "#c3c3c3",
                "text.muted": "#c3c3c370",
                "text.ignored": "#c3c3c340",
                "text.placeholder": "#c3c3c350",
                "ignored": "#c3c3c330",
                "element.hover": "#c3c3c330",
                "ghost_element.hover": "#71342A30",
                "ghost_element.selected": "#71342A30",
                "ghost_element.active": "#71342A60",
                "border": "#121212",
                "editor.highlighted_line.background": "#71342A10",
                "editor.active_line.background": "#71342A10",
                "panel.background": "#12121290",
                "title_bar.background": "#12121290",
                "title_bar.inactive_background": "#12121290",
                "status_bar.background": "#12121290",
                "drop_target.background": "#12121290",
                "elevated_surface.background": "#121212",
                "toolbar.background": "#12121290",
                "tab_bar.background": "#12121290",
                "tab.inactive_background": "#12121290",
                "tab.active_background": "#71342A30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#121212",
                "scrollbar.thumb.background": "#71342A",
                "editor.gutter.background": "#12121290",
                "terminal.background": "#12121210",
                "terminal.foreground": "#c3c3c3",
                "terminal.dim_foreground": "#c3c3c3",
                "terminal.bright_foreground": "#c3c3c3",
                "terminal.ansi.black": "#121212",
                "terminal.ansi.red": "#71342A",
                "terminal.ansi.green": "#8F3A2B",
                "terminal.ansi.yellow": "#AD3D29",
                "terminal.ansi.blue": "#CE3F27",
                "terminal.ansi.magenta": "#964232",
                "terminal.ansi.cyan": "#B0422E",
                "terminal.ansi.white": "#c3c3c3",
                "terminal.ansi.bright_black": "#6e5959",
                "terminal.ansi.bright_red": "#71342A",
                "terminal.ansi.bright_green": "#8F3A2B",
                "terminal.ansi.bright_yellow": "#AD3D29",
                "terminal.ansi.bright_blue": "#CE3F27",
                "terminal.ansi.bright_magenta": "#964232",
                "terminal.ansi.bright_cyan": "#B0422E",
                "terminal.ansi.bright_white": "#c3c3c3",
                "modified": "#71342A",
                "syntax": {
                    "attribute": {
                        "color": "#71342A"
                    },
                    "boolean": {
                      "color": "#8F3A2B"
                    },
                    "comment": {
                      "color": "#6e5959"
                    },
                    "comment.doc": {
                      "color": "#6e5959"
                    },
                    "constant": {
                      "color": "#8F3A2B"
                    },
                    "function": {
                      "color": "#B0422E"
                    },
                    "keyword": {
                      "color": "#CE3F27"
                    },
                    "number": {
                      "color": "#964232"
                    },
                    "operator": {
                      "color": "#CE3F27"
                    },
                    "string": {
                      "color": "#71342A"
                    },
                    "variable": {
                      "color": "#8F3A2B"
                    }
                },
                "players": [
                  {
                    "cursor": "#71342A",
                    "background": "#121212",
                    "selection": "#71342A30"
                  }
                ]
            }
        }
    ]
}
