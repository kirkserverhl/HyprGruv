{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#10101190",
                "editor.background": "#10101190",
                "editor.foreground": "#c3c3c3",
                "text": "#c3c3c3",
                "text.muted": "#c3c3c370",
                "text.ignored": "#c3c3c340",
                "text.placeholder": "#c3c3c350",
                "ignored": "#c3c3c330",
                "element.hover": "#c3c3c330",
                "ghost_element.hover": "#689E6B30",
                "ghost_element.selected": "#689E6B30",
                "ghost_element.active": "#689E6B60",
                "border": "#101011",
                "editor.highlighted_line.background": "#689E6B10",
                "editor.active_line.background": "#689E6B10",
                "panel.background": "#10101190",
                "title_bar.background": "#10101190",
                "title_bar.inactive_background": "#10101190",
                "status_bar.background": "#10101190",
                "drop_target.background": "#10101190",
                "elevated_surface.background": "#101011",
                "toolbar.background": "#10101190",
                "tab_bar.background": "#10101190",
                "tab.inactive_background": "#10101190",
                "tab.active_background": "#689E6B30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#101011",
                "scrollbar.thumb.background": "#689E6B",
                "editor.gutter.background": "#10101190",
                "terminal.background": "#10101110",
                "terminal.foreground": "#c3c3c3",
                "terminal.dim_foreground": "#c3c3c3",
                "terminal.bright_foreground": "#c3c3c3",
                "terminal.ansi.black": "#101011",
                "terminal.ansi.red": "#689E6B",
                "terminal.ansi.green": "#DB981D",
                "terminal.ansi.yellow": "#CA992E",
                "terminal.ansi.blue": "#D9A124",
                "terminal.ansi.magenta": "#938B75",
                "terminal.ansi.cyan": "#438489",
                "terminal.ansi.white": "#c3c3c3",
                "terminal.ansi.bright_black": "#59596d",
                "terminal.ansi.bright_red": "#689E6B",
                "terminal.ansi.bright_green": "#DB981D",
                "terminal.ansi.bright_yellow": "#CA992E",
                "terminal.ansi.bright_blue": "#D9A124",
                "terminal.ansi.bright_magenta": "#938B75",
                "terminal.ansi.bright_cyan": "#438489",
                "terminal.ansi.bright_white": "#c3c3c3",
                "modified": "#689E6B",
                "syntax": {
                    "attribute": {
                        "color": "#689E6B"
                    },
                    "boolean": {
                      "color": "#DB981D"
                    },
                    "comment": {
                      "color": "#59596d"
                    },
                    "comment.doc": {
                      "color": "#59596d"
                    },
                    "constant": {
                      "color": "#DB981D"
                    },
                    "function": {
                      "color": "#438489"
                    },
                    "keyword": {
                      "color": "#D9A124"
                    },
                    "number": {
                      "color": "#938B75"
                    },
                    "operator": {
                      "color": "#D9A124"
                    },
                    "string": {
                      "color": "#689E6B"
                    },
                    "variable": {
                      "color": "#DB981D"
                    }
                },
                "players": [
                  {
                    "cursor": "#689E6B",
                    "background": "#101011",
                    "selection": "#689E6B30"
                  }
                ]
            }
        }
    ]
}
