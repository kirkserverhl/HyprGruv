{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#11111990",
                "editor.background": "#11111990",
                "editor.foreground": "#c3c3c5",
                "text": "#c3c3c5",
                "text.muted": "#c3c3c570",
                "text.ignored": "#c3c3c540",
                "text.placeholder": "#c3c3c550",
                "ignored": "#c3c3c530",
                "element.hover": "#c3c3c530",
                "ghost_element.hover": "#625D6930",
                "ghost_element.selected": "#625D6930",
                "ghost_element.active": "#625D6960",
                "border": "#111119",
                "editor.highlighted_line.background": "#625D6910",
                "editor.active_line.background": "#625D6910",
                "panel.background": "#11111990",
                "title_bar.background": "#11111990",
                "title_bar.inactive_background": "#11111990",
                "status_bar.background": "#11111990",
                "drop_target.background": "#11111990",
                "elevated_surface.background": "#111119",
                "toolbar.background": "#11111990",
                "tab_bar.background": "#11111990",
                "tab.inactive_background": "#11111990",
                "tab.active_background": "#625D6930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#111119",
                "scrollbar.thumb.background": "#625D69",
                "editor.gutter.background": "#11111990",
                "terminal.background": "#11111910",
                "terminal.foreground": "#c3c3c5",
                "terminal.dim_foreground": "#c3c3c5",
                "terminal.bright_foreground": "#c3c3c5",
                "terminal.ansi.black": "#111119",
                "terminal.ansi.red": "#625D69",
                "terminal.ansi.green": "#5E6176",
                "terminal.ansi.yellow": "#63677C",
                "terminal.ansi.blue": "#6E7288",
                "terminal.ansi.magenta": "#847B84",
                "terminal.ansi.cyan": "#7D8299",
                "terminal.ansi.white": "#c3c3c5",
                "terminal.ansi.bright_black": "#5c5c70",
                "terminal.ansi.bright_red": "#625D69",
                "terminal.ansi.bright_green": "#5E6176",
                "terminal.ansi.bright_yellow": "#63677C",
                "terminal.ansi.bright_blue": "#6E7288",
                "terminal.ansi.bright_magenta": "#847B84",
                "terminal.ansi.bright_cyan": "#7D8299",
                "terminal.ansi.bright_white": "#c3c3c5",
                "modified": "#625D69",
                "syntax": {
                    "attribute": {
                        "color": "#625D69"
                    },
                    "boolean": {
                      "color": "#5E6176"
                    },
                    "comment": {
                      "color": "#5c5c70"
                    },
                    "comment.doc": {
                      "color": "#5c5c70"
                    },
                    "constant": {
                      "color": "#5E6176"
                    },
                    "function": {
                      "color": "#7D8299"
                    },
                    "keyword": {
                      "color": "#6E7288"
                    },
                    "number": {
                      "color": "#847B84"
                    },
                    "operator": {
                      "color": "#6E7288"
                    },
                    "string": {
                      "color": "#625D69"
                    },
                    "variable": {
                      "color": "#5E6176"
                    }
                },
                "players": [
                  {
                    "cursor": "#625D69",
                    "background": "#111119",
                    "selection": "#625D6930"
                  }
                ]
            }
        }
    ]
}
