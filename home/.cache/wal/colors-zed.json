{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#17181890",
                "editor.background": "#17181890",
                "editor.foreground": "#c5c5c5",
                "text": "#c5c5c5",
                "text.muted": "#c5c5c570",
                "text.ignored": "#c5c5c540",
                "text.placeholder": "#c5c5c550",
                "ignored": "#c5c5c530",
                "element.hover": "#c5c5c530",
                "ghost_element.hover": "#D75D0E30",
                "ghost_element.selected": "#D75D0E30",
                "ghost_element.active": "#D75D0E60",
                "border": "#171818",
                "editor.highlighted_line.background": "#D75D0E10",
                "editor.active_line.background": "#D75D0E10",
                "panel.background": "#17181890",
                "title_bar.background": "#17181890",
                "title_bar.inactive_background": "#17181890",
                "status_bar.background": "#17181890",
                "drop_target.background": "#17181890",
                "elevated_surface.background": "#171818",
                "toolbar.background": "#17181890",
                "tab_bar.background": "#17181890",
                "tab.inactive_background": "#17181890",
                "tab.active_background": "#D75D0E30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#171818",
                "scrollbar.thumb.background": "#D75D0E",
                "editor.gutter.background": "#17181890",
                "terminal.background": "#17181810",
                "terminal.foreground": "#c5c5c5",
                "terminal.dim_foreground": "#c5c5c5",
                "terminal.bright_foreground": "#c5c5c5",
                "terminal.ansi.black": "#171818",
                "terminal.ansi.red": "#D75D0E",
                "terminal.ansi.green": "#C25711",
                "terminal.ansi.yellow": "#D66410",
                "terminal.ansi.blue": "#D7921F",
                "terminal.ansi.magenta": "#D79921",
                "terminal.ansi.cyan": "#DBA436",
                "terminal.ansi.white": "#c5c5c5",
                "terminal.ansi.bright_black": "#725d5d",
                "terminal.ansi.bright_red": "#D75D0E",
                "terminal.ansi.bright_green": "#C25711",
                "terminal.ansi.bright_yellow": "#D66410",
                "terminal.ansi.bright_blue": "#D7921F",
                "terminal.ansi.bright_magenta": "#D79921",
                "terminal.ansi.bright_cyan": "#DBA436",
                "terminal.ansi.bright_white": "#c5c5c5",
                "modified": "#D75D0E",
                "syntax": {
                    "attribute": {
                        "color": "#D75D0E"
                    },
                    "boolean": {
                      "color": "#C25711"
                    },
                    "comment": {
                      "color": "#725d5d"
                    },
                    "comment.doc": {
                      "color": "#725d5d"
                    },
                    "constant": {
                      "color": "#C25711"
                    },
                    "function": {
                      "color": "#DBA436"
                    },
                    "keyword": {
                      "color": "#D7921F"
                    },
                    "number": {
                      "color": "#D79921"
                    },
                    "operator": {
                      "color": "#D7921F"
                    },
                    "string": {
                      "color": "#D75D0E"
                    },
                    "variable": {
                      "color": "#C25711"
                    }
                },
                "players": [
                  {
                    "cursor": "#D75D0E",
                    "background": "#171818",
                    "selection": "#D75D0E30"
                  }
                ]
            }
        }
    ]
}
