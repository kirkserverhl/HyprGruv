{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#12121290",
                "editor.background": "#12121290",
                "editor.foreground": "#c3c3c3",
                "text": "#c3c3c3",
                "text.muted": "#c3c3c370",
                "text.ignored": "#c3c3c340",
                "text.placeholder": "#c3c3c350",
                "ignored": "#c3c3c330",
                "element.hover": "#c3c3c330",
                "ghost_element.hover": "#6A6D7330",
                "ghost_element.selected": "#6A6D7330",
                "ghost_element.active": "#6A6D7360",
                "border": "#121212",
                "editor.highlighted_line.background": "#6A6D7310",
                "editor.active_line.background": "#6A6D7310",
                "panel.background": "#12121290",
                "title_bar.background": "#12121290",
                "title_bar.inactive_background": "#12121290",
                "status_bar.background": "#12121290",
                "drop_target.background": "#12121290",
                "elevated_surface.background": "#121212",
                "toolbar.background": "#12121290",
                "tab_bar.background": "#12121290",
                "tab.inactive_background": "#12121290",
                "tab.active_background": "#6A6D7330",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#121212",
                "scrollbar.thumb.background": "#6A6D73",
                "editor.gutter.background": "#12121290",
                "terminal.background": "#12121210",
                "terminal.foreground": "#c3c3c3",
                "terminal.dim_foreground": "#c3c3c3",
                "terminal.bright_foreground": "#c3c3c3",
                "terminal.ansi.black": "#121212",
                "terminal.ansi.red": "#6A6D73",
                "terminal.ansi.green": "#797C83",
                "terminal.ansi.yellow": "#817F84",
                "terminal.ansi.blue": "#7D8288",
                "terminal.ansi.magenta": "#909499",
                "terminal.ansi.cyan": "#999EA2",
                "terminal.ansi.white": "#c3c3c3",
                "terminal.ansi.bright_black": "#6e5959",
                "terminal.ansi.bright_red": "#6A6D73",
                "terminal.ansi.bright_green": "#797C83",
                "terminal.ansi.bright_yellow": "#817F84",
                "terminal.ansi.bright_blue": "#7D8288",
                "terminal.ansi.bright_magenta": "#909499",
                "terminal.ansi.bright_cyan": "#999EA2",
                "terminal.ansi.bright_white": "#c3c3c3",
                "modified": "#6A6D73",
                "syntax": {
                    "attribute": {
                        "color": "#6A6D73"
                    },
                    "boolean": {
                      "color": "#797C83"
                    },
                    "comment": {
                      "color": "#6e5959"
                    },
                    "comment.doc": {
                      "color": "#6e5959"
                    },
                    "constant": {
                      "color": "#797C83"
                    },
                    "function": {
                      "color": "#999EA2"
                    },
                    "keyword": {
                      "color": "#7D8288"
                    },
                    "number": {
                      "color": "#909499"
                    },
                    "operator": {
                      "color": "#7D8288"
                    },
                    "string": {
                      "color": "#6A6D73"
                    },
                    "variable": {
                      "color": "#797C83"
                    }
                },
                "players": [
                  {
                    "cursor": "#6A6D73",
                    "background": "#121212",
                    "selection": "#6A6D7330"
                  }
                ]
            }
        }
    ]
}
