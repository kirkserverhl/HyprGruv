/* Compact launcher / keybind hint picker — launcher-matched */

configuration {
    modi:                "drun,run,filebrowser,keys";
    show-icons:          true;
    icon-theme:          "Gruvbox Plus Dark";
    display-drun:        "APPS";
    display-run:         "RUN";
    display-filebrowser: "FILES";
    display-window:      "WINDOW";
    hover-select:        false;
    scroll-method:       1;
    me-select-entry:     "";
    me-accept-entry:     "MousePrimary";
    drun-display-format: "{name}";
    window-format:       "{w}  {c}  {t}";
}

@import "~/.config/rofi/shared/standard.rasi"
@import "~/.config/rofi/shared/launcher-chrome.rasi"

window {
    width:    600px;
    y-offset: 65px;
    location: north;
    anchor:   north;
}

mainbox {
    children: ["listbox"];
}

listbox {
    children: ["inputbar", "message", "listview"];
}

listview {
    lines:        8;
    fixed-height: true;
    cycle:        false;
    dynamic:      false;
}

element-icon {
    size: 32px;
}