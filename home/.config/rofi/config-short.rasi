/* Short confirmation menu — launcher-matched */

configuration {
    modi:                "drun,run";
    show-icons:          false;
    icon-theme:          "kora";
    display-drun:        "APPS";
    display-run:         "RUN";
    hover-select:        true;
    me-select-entry:     "";
    me-accept-entry:     "MousePrimary";
    drun-display-format: "{name}";
    window-format:       "{w} · {c} · {t}";
}

@import "~/.config/rofi/shared/standard.rasi"
@import "~/.config/rofi/shared/launcher-chrome.rasi"

window {
    width:    200px;
    height:   130px;
    x-offset: -14px;
    y-offset: 65px;
    location: northeast;
    anchor:   northeast;
}

mainbox {
    children: ["listbox"];
}

listbox {
    children: ["listview"];
}

listview {
    lines:        2;
    fixed-height: true;
}