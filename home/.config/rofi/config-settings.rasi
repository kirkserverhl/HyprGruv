/* HyprGruv Settings — square icon grid (wlogout-style) */

configuration {
    show-icons:      true;
    icon-theme:      "Gruvbox Plus Dark";
    hover-select:    false;
    me-select-entry: "";
    me-accept-entry: "MousePrimary";
    cycle:           false;
}

@import "~/.config/rofi/shared/standard.rasi"
@import "~/.config/rofi/shared/launcher-chrome.rasi"

window {
    location: center;
    anchor:   center;
}

mainbox {
    spacing:  10px;
    padding:  16px;
    children: ["inputbar", "listview"];
}

inputbar {
    children: [ "prompt" ];
    padding:  0 0 4px 0;
}

prompt {
    enabled:    true;
    text-color: @prompt-color;
    padding:    0;
}

entry {
    enabled: false;
}

listview {
    columns:      2;
    lines:        2;
    fixed-height: true;
    fixed-columns: true;
    cycle:        false;
    dynamic:      false;
    layout:       vertical;
    spacing:      10px;
    padding:      2px;
}

element {
    orientation:      vertical;
    padding:          16px 12px;
    border-radius:    18px;
    background-color: @background-alt;
    min-width:        120px;
    min-height:       120px;
}

element selected {
    background-color: @selected;
    text-color:       @selected-fg;
    border-radius:    18px;
}

element-icon {
    size:             52px;
    horizontal-align: 0.5;
    margin:           0 0 8px 0;
}

element-text {
    horizontal-align: 0.5;
    vertical-align:   0.5;
    margin:           0;
}