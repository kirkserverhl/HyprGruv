/* Curated favorites launcher — waypaper-matched chrome */

configuration {
    modi:                       "drun";
    show-icons:                 true;
    icon-theme:                 "Gruvbox-Plus-Dark";
    application-fallback-icon:  "application-x-executable";
    display-drun:               "APPS";
    drun-display-format:        "{name}";
    scroll-method:              1;
}

@import "~/.config/rofi/shared/standard.rasi"
@import "~/.config/rofi/shared/launcher-chrome.rasi"

window {
    width:    480px;
    location: center;
    anchor:   center;
}

mainbox {
    children: ["listbox"];
}

listbox {
    children: ["inputbar", "listview"];
}

entry {
    placeholder: "Search apps...";
}

listview {
    lines:        10;
    fixed-height: true;
}

element-icon {
    size: 28px;
}