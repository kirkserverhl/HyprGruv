    "on-click-right": "~/scripts/terminal.sh",
    "tooltip-format": "Left:   Firefox   🦊\nRight: Ghostty 👻"
  },
  "custom/quicklink3": {
    "format": "",
    "on-click": "~/scripts/filemanager.sh",
    "on-click-right": "~/scripts/yazi.sh",
    "tooltip-format": "Left:  Dolphin 🐬 \nRight:   Yazi  🦆"
  },
  "custom/quicklink4": {
    "format": "",
    "on-click": "xdg-open https://gmail.com",
    "tooltip-format": "Gmail  📧"
  },
  "custom/quicklink5": {
    "format": "",
    "on-click": "~/scripts/calculator.sh",
    "tooltip-format": "Open calculator"
  },
  "custom/quicklink6": {
    "format": "",
    "on-click": "~/scripts/emojipicker.sh",
    "tooltip-format": " Smile 💀"
