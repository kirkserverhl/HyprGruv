{
  "custom/quicklink1": {
    "format": "",
    "on-click": "chromium",
    "tooltip-format": "Open Chromium"
  },
  "custom/quicklink2": {
    "format": "",
    "on-click": "~/.config/settings/browser.sh",
    "on-click-right": "~/.config/settings/terminal.sh",
    "tooltip-format": "Left:   Firefox \nRight: Ghostty "
  },
  "custom/quicklink3": {
    "format": "",
    "on-click": "~/.config/settings/filemanager.sh",
    "on-click-right": "~/.config/hyprgruv/scripts/yazi.sh",
    "tooltip-format": "Left:    Dolphin  \nRight:   Yazi "
  },
  "custom/quicklink4": {
    "format": "",
    "on-click": "xdg-open https://gmail.com",
    "tooltip-format": "Gmail "
  },
  "custom/quicklink5": {
    "format": "",
    "on-click": "~/.config/hyprgruv/scripts/rofi_calc.sh",
    "tooltip-format": "Open calculator"
  },
  "custom/quicklink6": {
    "format": "",
    "on-click": "~/.config/settings/emojipicker.sh",
    "tooltip-format": " Hypremoji"
  },
  "custom/quicklinkempty": {},
  "group/quicklinks": {
    "orientation": "horizontal",
    "modules": [
      "custom/quicklink2",
      "custom/quicklink3",
      "custom/quicklink4",
      "custom/quicklinkempty"
    ]
  }
}
