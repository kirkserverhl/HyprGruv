#!/bin/bash
# ASCII header generator — toilet graffiti + clipboard copy

source "$HOME/.config/hypr/scripts/header.sh" 2>/dev/null || true
source "$HOME/.config/hypr/scripts/colors.sh" 2>/dev/null || true

_render_ascii() {
    local text="$1"
    if command -v toilet >/dev/null 2>&1; then
        toilet -f graffiti "$text"
        return 0
    fi
    if command -v figlet >/dev/null 2>&1; then
        figlet -f graffiti "$text" 2>/dev/null || figlet "$text"
        return 0
    fi
    printf '=== %s ===\n' "$text"
}

echo
read -p "Enter the text for ASCII encoding: " mytext

if [ -z "$mytext" ]; then
    echo "No text entered. Exiting."
    exit 1
fi

if declare -f display_header >/dev/null 2>&1; then
    display_header "$mytext"
else
    _render_ascii "$mytext"
fi

output_file=~/figlet.txt
echo "Saving output to $output_file..."
_render_ascii "$mytext" >"$output_file"

echo "Contents of the file:"
cat "$output_file"

if command -v wl-copy &>/dev/null; then
    wl-copy <"$output_file"
    echo "Text copied to clipboard (wl-copy)."
elif command -v xclip &>/dev/null; then
    xclip -sel clip <"$output_file"
    echo "Text copied to clipboard (xclip)."
else
    echo "Clipboard tool not found. Please install 'wl-copy' or 'xclip'."
fi