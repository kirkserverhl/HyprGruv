{
  "version": 1,
  "description": "Matugen-like but backwards: UI spectrum columns are filled from literal wallpaper hues (high hue → low). Starship, Waybar, and Hyprbars share the same inward order.",
  "wallpaper_only": true,
  "ui_order": ["purple", "blue", "green", "yellow", "orange", "red"],
  "note": "Most wallpapers only supply ~4 distinct accents (through yellow). Orange/red columns are omitted — Starship segments past yellow simply do not render.",
