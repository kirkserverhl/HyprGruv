      "base16": "base0f",
      "spectrum": "color_orange",
      "starship": "os / username",
      "waybar": "appmenu / pulseaudio (left)",
      "hyprbars": "close"
    },
    {
      "hue": "blue",
      "base16": "base08",
      "spectrum": "color_yellow",
      "starship": "directory",
      "waybar": "settings / clock",
      "hyprbars": "minimize"
    },
    {
      "hue": "green",
