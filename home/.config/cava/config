## CAVA configuration
## Colors are generated by matugen → ~/.config/cava/themes/matugen

[general]
live-config = 1
framerate = 60
autosens = 1
sensitivity = 100
bars = 0
bar_width = 2
bar_spacing = 1
center_align = 1

[input]
method = pipewire
source = auto

[output]
method = noncurses

[color]
theme = 'matugen'