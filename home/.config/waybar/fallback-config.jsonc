{
  "include": "~/.config/waybar/modules.json",

  "layer": "top",
  "position": "top",
  "height": 42,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": [
    "custom/appmenu",
    "custom/settings",
    "custom/media"
  ],

  "modules-center": [
    "hyprland/workspaces"
  ],

  "modules-right": [
    "custom/updates",
    "pulseaudio",
    "network",
    "battery",
    "clock",
    "custom/power"
  ]
}
