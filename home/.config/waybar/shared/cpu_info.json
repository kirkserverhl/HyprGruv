{
  "cpu": {
    "interval": 1,
    "format": "\udb83\udee0",
    "tooltip-format": "CPU: {usage}%"
  },

  "memory": {
    "format": "\uefc5 {percentage}%"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power mode: {profile}",
    "tooltip": true,
    "format-icons": {
      "default": "\uf0e7",
      "performance": "\udb82\udc20",
      "balanced": "\udb81\ude80",
      "power-saver": "\udb80\udf2a"
    }
  },

  "network": {
    "interface": "wlo1",
    "format": "{ifname}",
    "format-wifi": "{icon}",
    "format-ethernet": "\udb80\ude00",
    "format-disconnected": "\udb82\udd2d",
    "max-length": 50,
    "format-icons": [
      "\udb82\udd2f",
      "\udb82\udd1f",
      "\udb82\udd22",
      "\udb82\udd25",
      "\udb82\udd28"
    ],
    "tooltip-format": "Network Manager",
    "on-click": "~/.config/hyprgruv/scripts/networkmanager.sh"
  },

  "group/cpu-info": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-cpu",
      "transition-left-to-right": false
    },
    "on-click": "~/.config/hyprgruv/scripts/bpytop.sh",
    "on-click-right": "~/.config/hyprgruv/scripts/htop.sh",
    "tooltip-format": "Left: Btop\nRight: Htop",
    "modules": [
      "cpu",
      "memory",
      "power-profiles-daemon",
      "network"
    ]
  }
}