{
  "network": {
    "interface": "wlo1",
    "format": "{ifname}",
    "format-wifi": "{icon}",
    "format-ethernet": "\udb80\ude00",
    "format-disconnected": "\udb82\udd2d",
    "max-length": 50,
    "format-icons": [
      "\udb82\udd2f",
      "\udb82\udd1f",
      "\udb82\udd22",
      "\udb82\udd25",
      "\udb82\udd28"
    ],
    "tooltip-format": "Network Manager",
    "on-click": "~/.config/hyprgruv/scripts/networkmanager.sh"
  },

  "custom/system": {
    "format": " \uf4bc ",
    "tooltip": false
  },

  "memory": {
    "format": "\uefc5 {percentage}%"
  },

  "group/cpu-info": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-system",
      "transition-left-to-right": false
    },
    "on-click": "~/.config/hyprgruv/scripts/bpytop.sh",
    "on-click-right": "~/.config/hyprgruv/scripts/htop.sh",
    "tooltip-format": "Left: Btop\nRight: Htop",
    "modules": [
      "custom/system",
      "cpu",
      "memory",
      "disk",
      "hyprland/language",
      "network"
    ]
  }
}
