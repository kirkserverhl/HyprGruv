{
  "custom/updates": {
    "exec": "~/.config/hyprgruv/scripts/updates.sh waybar",
    "interval": 1800,
    "return-type": "json",
    "format": "{}",
    "on-click": "kitty --class hypr-updates -e ~/.config/hyprgruv/scripts/installupdates.sh",
    "on-click-right": "~/.config/hyprgruv/scripts/software.sh",
    "tooltip-format": "Left: Updates\nRight: Pacseek"
  }
}