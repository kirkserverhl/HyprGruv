{
  "custom/settings": {
    "format": "\udb81\udc93",
    "on-click": "~/.config/hyprgruv/scripts/hyprgruv-settings.sh",
    "on-click-right": "sleep 05; ~/.config/hyprgruv/scripts/blitz-mode.sh",
    "tooltip-format": "Settings App"
  },

  "custom/waybarthemes": {
    "format": "\uf141",
    "on-click": "~/.config/hyprgruv/scripts/themeswitcher.sh",
    "on-click-right": "killall -9 waybar",
    "tooltip-format": "Left: Waybar themes\nRight: KILL"
  },

  "custom/wallpaper": {
    "format": "\uf03e",
    "on-click": "waypaper",
    "on-click-right": "sleep 05; ~/.config/hyprgruv/scripts/palette-pick.sh",
    "tooltip-format": "Left: Wallpaper\nRight: Pallete"
  },

  "custom/hyprsunset": {
    "format": "\ue4dc",
    "tooltip-format": "Toggle screen shader",
    "on-click": "~/.config/hyprgruv/scripts/hyprshade.sh",
    "on-click-right": "sleep 0.5; ~/.config/hyprgruv/scripts/hyprshade.sh rofi"
  },

  "group/settings": {
    "orientation": "horizontal",
    "tooltip-format": "Settings App",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-settings",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/settings",
      "custom/waybarthemes",
      "custom/wallpaper",
      "custom/hyprsunset"
    ]
  }
}
