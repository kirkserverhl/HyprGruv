{
  "custom/settings": {
    "format": "\udb81\udc93",
    "on-click": "~/.config/hyprgruv/scripts/waybar-theme.sh",
    "tooltip-format": "Settings App"
  },

  "custom/waybarthemes": {
    "format": "\uf141",
    "on-click": "~/.config/hyprgruv/scripts/themeswitcher.sh",
    "on-click-right": "~/.config/hyprgruv/scripts/animations.sh",
    "tooltip-format": "Left: Waybar themes\nRight: Animations"
  },

  "custom/wallpaper": {
    "format": "\uf03e",
    "on-click": "waypaper",
    "on-click-right": "~/.config/hyprgruv/scripts/decorations.sh",
    "tooltip-format": "Left: Wallpaper\nRight: Decorations"
  },

  "group/settings": {
    "orientation": "horizontal",
    "tooltip-format": "Settings App",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-settings",
      "transition-left-to-right": true
    },
    "modules": ["custom/settings", "custom/waybarthemes", "custom/wallpaper"]
  }
}