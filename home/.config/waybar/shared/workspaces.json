{
  "hyprland/workspaces": {
    "format": "{id}",
    "format-icons": {
      "active": "",
      "default": "",
      "urgent": ""
    },
    "on-click": "activate",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "all-outputs": false,
    "persistent-only": true,
    "show-special": false,
    "ignore-workspaces": ["special:.*"],
    "persistent-workspaces": {
      "DP-1": [1, 2],
      "DVI-I-1": [3, 4],
      "HDMI-A-1": [5, 6],
      "DVI-I-2": [7, 8],
      "*": [1, 2]
    }
  },

  "custom/special": {
    "exec": "~/.config/waybar/scripts/special-workspace.sh",
    "return-type": "json",
    "format": "{}",
    "on-click": "hyprctl dispatch togglespecialworkspace scratchpad",
    "interval": 2,
    "tooltip": true
  }
}