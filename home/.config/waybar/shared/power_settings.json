{
  "custom/power": {
    "format": "\udb81\udc25 ",
    "on-click": "~/.config/hypr/scripts/launch-wlogout.sh",
    "tooltip-format": "Power Menu"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power mode: {profile}",
    "tooltip": true,
    "format-icons": {
      "default": "\uf0e7",
      "performance": "\udb82\udc20",
      "balanced": "\udb81\ude80",
      "power-saver": "\udb80\udf2a"
    }
  },

  "group/power": {
    "orientation": "horizontal",
    "tooltip-format": "Power Menu",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-power",
      "transition-left-to-right": false
    },
    "modules": ["custom/power", "power-profiles-daemon"]
  }
}


