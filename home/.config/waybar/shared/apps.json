{
  "custom/appmenu": {
    "format": " \uf303 ",
    "on-click": "~/.config/hyprgruv/scripts/rofi-full.sh",
    "on-click-right": "~/.config/hyprgruv/scripts/rofi-apps.sh",
    "tooltip-format": "Left: All Apps\nRight: Favorites"
  },

  "custom/tools": {
    "format": " \ueb52 ",
    "on-click": "~/.config/hyprgruv/scripts/rofi-full.sh",
    "tooltip-format": "Tools & Utilities"
  },

  "custom/cliphist": {
    "format": " \udb80\udd4c ",
    "on-click": "~/.config/hyprgruv/scripts/hyprshot.sh",
    "on-click-right": "~/.config/hyprgruv/scripts/cliphist.sh",
    "tooltip-format": "Left: Screenshot\nRight: Clipboard history"
  },

  "custom/hypridle": {
    "format": " \uf023 ",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/.config/hyprgruv/scripts/hypridle.sh status",
    "on-click": "~/.config/hyprgruv/scripts/hypridle.sh toggle",
    "on-click-right": "hyprlock",
    "tooltip": false
  },

  "custom/hyprsunset": {
    "format": "\ue4dc",
    "tooltip-format": "Toggle screen shader",
    "on-click": "~/.config/hyprgruv/scripts/hyprshade.sh",
    "on-click-right": "sleep 0.5; ~/.config/hyprgruv/scripts/hyprshade.sh rofi"
  },

  "group/apps": {
    "orientation": "horizontal",
    "tooltip-format": "Left: All Apps\nRight: Favorites",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-apps",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/appmenu",
      "custom/tools",
      "custom/cliphist",
      "custom/hypridle",
      "custom/hyprsunset"
    ]
  }
}

