{
  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate"
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 50
  },
  "custom/appmenu": {
    "format": "\udb82\udcc7",
    "on-click": "pkill rofi || rofi -show drun -replace",
    "tooltip": false
  },
  "custom/appmenuicon": {
    "format": "\uf303",
    "on-click": "sleep 0.2;rofi -show drun -replace",
    "on-click-right": "~/scripts/launch.sh",
    "tooltip-format": "Left: Open Rofi \ud83d\udd33\nRight: Open Apps \ud83c\udfc3\u2642\ufe0f"
  },
  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%Y-%m-%d  %H:%M:%S}",
    "on-click": "mode",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>"
  },
  "custom/system": {
    "format": "\ue473",
    "tooltip": false
  },
  "cpu": {
    "format": "/ C {usage}% ",
    "on-click": "~/scripts/system-monitor.sh"
  },
  "memory": {
    "format": "/ M {}% ",
    "on-click": "~/scripts/system-monitor.sh"
  },
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "~/scripts/system-monitor.sh"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": [
      "\udb80\udc7a",
      "\udb80\udc7b",
      "\udb80\udc7c",
      "\udb80\udc7d",
      "\udb80\udc7e",
      "\udb80\udc7f",
      "\udb80\udc80",
      "\udb80\udc81",
      "\udb80\udc82",
      "\udb80\udc79"
    ]
  },
  "network": {
    "format": "{}",
    "format-wifi": "\uf1eb   {signalStrength}%",
    "format-ethernet": "\uf796 ",
    "format-disconnected": "Disconnected",
    "tooltip-format": "\uf796 via {ifname} {gwaddri}",
    "tooltip-format-wifi": "\uf1eb  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "\uf796 {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "~/.config/hypr/scripts/networkmanager.sh",
    "on-click-right": "~/scripts/nm-applet.sh toggle"
  },
  "pulseaudio": {
    "scroll-step": 1,
    "format": " {icon} ",
    "format-bluetooth": "{volume}% {icon}\uf294 {format_source}",
    "format-bluetooth-muted": "\uf6a9 {icon}\uf294 {format_source}",
    "format-muted": "\uf6a9 {format_source}",
    "format-source": "{volume}% \uf130",
    "format-source-muted": "\uf131",
    "format-icons": {
      "headphone": "\uf025 ",
      "hands-free": "\uf590 ",
      "headset": "\uf590 ",
      "phone": "\uf095 ",
      "portable": "\uf095 ",
      "car": "\uf1b9 ",
      "default": ["\uf026", "\uf028", "\uf028"]
    },
    "on-click": "pavucontrol"
  },
  "bluetooth": {
    "format": "  ",
    "format-disabled": "\udb80\udcb2",
    "format-connected": "\udb80\udcb1 {num_connections}",
    "format-connected-battery": "\udb80\udcb1 {num_connections} \udb82\udd49 {battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "\t{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "\t{device_alias}\t{device_address}\t{battery_percentage}%",
    "on-click": "blueberry"
  },
  "custom/settings": {
    "format": "\udb81\udc93",
    "on-click": "~/.config/hypr/scripts/waybar-theme.sh",
    "tooltip": false
  },
  "custom/power": {
    "format": "\udb81\udc25 ",
    "on-click": "~/.config/hypr/scripts/launch-wlogout.sh",
    "tooltip": false
  },
  "custom/updates": {
    "exec": "~/.config/hypr/scripts/updates.sh",
    "interval": 1800,
    "return-type": "json",
    "format": "{}",
    "on-click": "~/.config/hypr/settings/installupdates.sh",
    "tooltip-format": "Click to install updates"
  },
  "custom/exit": {
    "format": "\udb81\udc25",
    "on-click": "~/.config/hypr/scripts/launch-wlogout.sh",
    "tooltip": false
  },
  "custom/media": {
    "exec": "~/.config/waybar/scripts/mediaplayer.py",
    "format": "{}",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-scroll-up": "playerctl previous",
    "on-scroll-down": "playerctl next",
    "escape": true,
    "max-length": 50
  },
  "group/media": {
    "orientation": "horizontal",
    "modules": ["pulseaudio", "bluetooth", "custom/media"]
  },
  "custom/notifications": {
    "format": "\ueaa2",
    "exec": "~/.config/waybar/scripts/notifications.sh",
    "interval": 5
  },
  "custom/appmenuicon": {
    "format": "",
    "on-click": "sleep 0.2;rofi -show drun -replace",
    "on-click-right": "~/.config/hypr/scripts/launch.sh",
    "tooltip-format": "Left: Open Rofi \nRight: Open Apps"
  },
  "custom/exit": {
    "format": "   ",
    "on-click": "~/scripts/wlogout.sh",
    "tooltip-format": "Power Menu"
  },
  "custom/hyprshade": {
    "format": "",
    "tooltip-format": "Toggle Screen Shader 🕶️",
    "on-click": "~/scripts/hyprshade.sh",
    "on-click-right": "sleep 0.5; ~/scripts/hyprshade.sh rofi"
  },
  "custom/hypridle": {
    "format": "  ",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/scripts/hypridle.sh status",
    "on-click": "~/scripts/hypridle.sh toggle",
    "on-click-right": "hyprlock"
  },
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "  ",
      "unlocked": "  "
    }
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },

  "custom/cliphist": {
    "format": " 󰅌 ",
    "on-click": "~/.config/hypr/scripts/cliphist.sh",
    "on-click-right": "~/.config/hypr/scripts/cliphist.sh d",
    "tooltip-format": "Clipboard History\nLeft: Open\nRight: Delete entry"
  },

  "custom/tools": {
    "format": "  ",
    "on-click": "pkill rofi || rofi -show drun -replace",
    "tooltip-format": "Tools & Utilities\n(Click to open app launcher or customize)"
  },

  "custom/system": {
    "format": "  ",
    "tooltip": false
  },
  "cpu": {
    "format": "/ C {usage}% ",
    "on-click": "~/.config/hypr/scripts/system-monitor.sh"
  },
  "memory": {
    "format": "/ M {}% ",
    "on-click": "~/.config/hypr/scripts/system-monitor.sh"
  },
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "~/.config/hypr/scripts/system-monitor.sh"
  },
  "hyprland/language": {
    "format": "/ K {short}"
  },
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": ["custom/system", "disk", "cpu", "memory", "hyprland/language"]
  },
  "group/tools": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/tools",
      "custom/cliphist",
      "custom/hypridle",
      "custom/hyprshade"
    ]
  },

  "group/network": {
    "orientation": "horizontal",
    "modules": [
      "network",
      "group/hardware",
      "group/tools"
    ]
  }
}
