# в”Џв”Џ в”Џв”Ѓв”ѓв”Ѓв”Џв”›в”Џв”Ѓв”›в”Џв”Ѓв”ѓв”›в”Џв”Ѓв”ѓв”ѓ    в”ѓ в”ѓв”Џв”Ѓв”ѓв”ѓ в”ѓ  в”ѓ в”ѓв”ѓ в”ѓв”Џв”Ѓв”ѓв”Џв”Ѓв”ѓв”ѓ  в”Џв”Ѓв”ѓв”Џв”Ѓ в”Џв”Ѓ
# в”ѓв”ѓв”ѓв”Џв”Ѓв”ѓ в”ѓ в”Џв”Ѓв”›в”Џв”Џв”›в”ѓв”Џв”Ѓв”ѓв”ѓ  в”Ѓв”›в”Ѓв”Џв”›в”ѓ в”ѓв”ѓ в”ѓ  в”Џв”Ѓв”ѓв”Ѓв”Џв”›в”Џв”Ѓв”›в”Џв”Џв”›в”ѓ  в”Џв”Ѓв”ѓв”ѓ в”ѓв”ѓ в”ѓ
# в”›в”›в”›в”› в”› в”› в”Ѓв”Ѓв”›в”› в”›в”›в”› в”›в”Ѓв”Ѓв”›   в”› в”Ѓв”Ѓв”›в”Ѓв”Ѓв”›  в”› в”› в”› в”›  в”› в”›в”Ѓв”Ѓв”›в”› в”›в”› в”›в”Ѓв”Ѓ

include colors/colors.conf

font_family       ShureTechMono Nerd Font # GeistMono Nerd Font Mono
font_size         12
italic_font       auto
bold_font         auto
bold_italic_font  auto
background_opacity .95


disable_ligatures yes
enable_audio_bell no

shell zsh
shell_integration disabled

cursor_shape          block

url_color #e8eaed
url_style curly

remember_window_size  no
# initial_window_width  640
# initial_window_height 400
initial_window_width  78c
initial_window_height 23c
window_padding_width  30

cursor_blink_interval 0
#cursor_blink_interval 0.5
#cursor_stop_blinking_after 0

scrollback_lines 5000
scrollback_lines 5000
scrollback_pager less +G -R
wheel_scroll_multiplier 1.0
click_interval 0.5

select_by_word_characters :@-./_~?&=%+#

enabled_layouts *
background_opacity 0.80
scrollbar_handle_opacity 0
scrollbar_track_opacity 0
scrollbar_track_hover_opacity 0
confirm_os_window_close 0

# -- Performance settings
sync_to_monitor no

# -- Speed shit up
allow_remote_control yes
listen_on unix:/tmp/kitty

# -- Perf
repaint_delay     8
input_delay       3
sync_to_monitor   yes

#cursor_blink_interval 0.5
#cursor_stop_blinking_after 0

remember_window_size   no
initial_window_width   640
initial_window_height  400
visual_bell_duration   0.0
open_url_with default
term xterm-kitty
hide_window_decorations no
kitty_mod ctrl+shift
clear_all_shortcuts yes
clipboard_control write-clipboard write-primary
map kitty_mod+c      copy_to_clipboard
map kitty_mod+v      paste_from_clipboard


# Scrolling
map kitty_mod+k         scroll_line_up
map kitty_mod+j         scroll_line_down

map kitty_mod+page_up   scroll_page_up
map kitty_mod+page_down scroll_page_down

map kitty_mod+home      scroll_home
map kitty_mod+end       scroll_end

map ctrl+left   resize_window narrower
map ctrl+right  resize_window wider
map ctrl+up     resize_window taller
map ctrl+down   resize_window shorter 3

# reset all windows in the tab to default sizes
# map ctrl+home resize_window reset

# window management
map kitty_mod+enter launch --cwd=current

map kitty_mod+w close_window
map kitty_mod+] next_window
map kitty_mod+[ previous_window
map kitty_mod+r start_resizing_window

# Tab management
map kitty_mod+h next_tab
map kitty_mod+l previous_tab
map kitty_mod+t new_tab
map kitty_mod+q close_tab

map kitty_mod+t new_tab_with_cwd

tab_bar_margin_width      5
tab_bar_margin_height     5 0
tab_bar_style             separator
tab_bar_min_tabs          2
tab_separator             ""

# Miscellaneous

#: It will copy only if there is a selection and send an interrupt otherwise.
map ctrl+c            copy_or_interrupt

map kitty_mod+plus      increase_font_size
map kitty_mod+minus     decrease_font_size
map kitty_mod+backspace restore_font_size

map kitty_mod+F11       toogle_fullscreen
map kitty_mod+F2        edit_config_file
map kitty_mod+F5        load_config_file

# Include theme
include ~/.cache/wal/colors-kitty.conf

