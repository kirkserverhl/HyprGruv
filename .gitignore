# Per-machine install progress (never commit — each clone gets a fresh run)
assets/install_state.json
assets/completed_steps.txt
assets/user_choices.txt

# Install logs (local only)
assets/logs/

# Oh My Zsh is installed locally by lib/scripts/oh_my_zsh.sh — never stow the upstream tree
home/.oh-my-zsh/

# Orphan npm vendor trees (reinstall via package.json if needed)
home/node_modules/

# KDE/Plasma session (not used on Hyprland)
home/.config/bluedevilglobalrc
home/.config/kglobalshortcutsrc
home/.config/kwinrc
home/.config/kwinoutputconfig.json
home/.config/kscreenlockerrc
home/.config/ksmserverrc
home/.config/ksplashrc
home/.config/plasma-*
home/.config/plasmarc
home/.config/plasmashellrc
home/.config/plasmanotifyrc
home/.config/kconf_updaterc
home/.config/kiorc
home/.config/kservicemenurc
home/.config/ktimezonedrc
home/.config/kuiviewerrc
home/.config/systemmonitorrc
home/.config/systemsettingsrc
home/.config/Designerrc
home/.config/filetypesrc
home/.config/trashrc
home/.config/window-geometry.conf
home/.config/xdg-desktop-portal-kderc
home/.config/KDE/

# Neovim runtime data (plugins, mason, parsers) — belongs in ~/.local/share/nvim
home/.config/rofi/apps-menu/nvim/

# Rofi apps-menu machine state (only applications/*.desktop is config)
home/.config/rofi/apps-menu/Trash/
home/.config/rofi/apps-menu/atuin/
home/.config/rofi/apps-menu/gvfs-metadata/
home/.config/rofi/apps-menu/mimeapps.list

# Fish machine state (universal variables; aliases.fish is stowed as empty stub)
home/.config/fish/fish_variables

# SwayNC matugen-generated (regenerated on wallpaper change)
home/.config/swaync/style.css
home/.config/swaync/matugen/

# VSCodium runtime data (only User/settings.json is config)
home/.config/VSCodium/**/state.vscdb*
home/.config/VSCodium/**/globalStorage/
home/.config/VSCodium/**/Cached*/
home/.config/VSCodium/**/blob_storage/
home/.config/VSCodium/**/Session Storage/
home/.config/VSCodium/**/Local Storage/

# Runtime / machine state
home/.config/dconf/
home/.config/last_wallpaper.txt
home/.config/*history*
home/.config/**/.current-theme
home/.config/**/*.db
home/.config/**/*.db-*
home/.config/**/error.log
home/.config/atuin/atuin-receipt.json