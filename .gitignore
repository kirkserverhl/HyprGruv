# Per-machine install progress (never commit — each clone gets a fresh run)
assets/install_state.json
assets/completed_steps.txt
assets/user_choices.txt

# Install logs (local only)
assets/logs/

# Oh My Zsh is installed locally by lib/scripts/oh_my_zsh.sh — never stow the upstream tree
home/.oh-my-zsh/

# Orphan npm vendor trees (reinstall via package.json if needed)
home/node_modules/

